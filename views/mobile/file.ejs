<div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl overflow-hidden">
  <div class="px-4 py-3.5 border-b border-neutral-200 dark:border-neutral-800">
    <div class="flex items-center justify-between mb-3">
      <div>
        <h2 class="text-sm font-semibold text-neutral-900 dark:text-white">Backups</h2>
        <p class="text-xs text-neutral-500 dark:text-neutral-600" id="backupSubtitle">Stored in Google Drive</p>
      </div>
      <button onclick="initiateCreate()"
        class="flex items-center gap-1.5 px-3.5 py-2 bg-emerald-600 text-white rounded-xl text-xs font-medium active:bg-emerald-700 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
        </svg>
        New
      </button>
    </div>
    <div class="flex gap-2">
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-neutral-400 dark:text-neutral-600 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
        </svg>
        <input type="text" id="backupSearch" placeholder="Search backups…" onkeyup="filterBackups()"
          class="w-full pl-9 pr-3 py-2 bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-xl text-xs text-neutral-900 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-600 focus:outline-none">
      </div>
      <select id="backupSort" onchange="sortBackups()"
        class="px-3 py-2 bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-xl text-xs text-neutral-600 dark:text-neutral-400 focus:outline-none appearance-none">
        <option value="date-desc">Newest</option>
        <option value="date-asc">Oldest</option>
        <option value="name-asc">A → Z</option>
        <option value="name-desc">Z → A</option>
        <option value="size-desc">Largest</option>
        <option value="size-asc">Smallest</option>
      </select>
    </div>
  </div>

  <div id="backupsList" class="min-h-[80px]">
    <div class="flex items-center justify-center py-8">
      <div class="w-5 h-5 border-2 border-emerald-500 border-t-transparent rounded-full animate-spin"></div>
    </div>
  </div>
</div>
