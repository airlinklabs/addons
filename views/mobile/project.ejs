<%- include(components.header, { title: title, user: user }) %>

<main class="min-h-screen pb-32">
  <%- include(components.template) %>

  <%
  const isProjectTypeDisabled = modrinthSettings?.modrinthInstallationWarning &&
    Array.isArray(modrinthSettings?.disabledProjectTypes) &&
    modrinthSettings.disabledProjectTypes.includes(project.project_type);
  const isProjectBlocked = modrinthSettings?.blockedProjects &&
    Array.isArray(modrinthSettings.blockedProjects) &&
    modrinthSettings.blockedProjects.includes(project.id);
  const isAnyInstallationBlocked = isProjectTypeDisabled || isProjectBlocked;
  %>

  <!-- Top nav -->
  <div class="sticky top-14 z-30 bg-white dark:bg-[#141414] border-b border-neutral-200 dark:border-white/5 px-4 py-2.5 flex items-center justify-between">
    <a href="/modrinth" class="flex items-center gap-1.5 text-sm text-neutral-500 dark:text-neutral-400">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Store
    </a>
    <button onclick="openProgressModal()" class="flex items-center gap-1.5 px-3 py-1.5 bg-emerald-600 text-white rounded-lg text-xs font-medium">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
      </svg>
      Status
    </button>
  </div>

  <% if (isAnyInstallationBlocked) { %>
  <div class="bg-amber-500/10 border-b border-amber-500/20 px-4 py-3">
    <div class="flex items-start gap-2">
      <svg class="w-4 h-4 text-amber-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
      </svg>
      <div>
        <p class="text-amber-400 text-sm font-medium"><%= modrinthSettings?.warningTitle || 'Installation Disabled' %></p>
        <p class="text-amber-200 text-xs mt-0.5"><%= modrinthSettings?.warningMessage || 'Installations are temporarily disabled.' %></p>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Project header card -->
  <div class="px-4 py-5 border-b border-neutral-200 dark:border-white/5">
    <div class="flex items-start gap-4">
      <div class="w-16 h-16 flex-shrink-0 rounded-xl overflow-hidden bg-neutral-100 dark:bg-neutral-800">
        <% if (project.icon_url) { %>
        <img src="<%= project.icon_url %>" alt="<%= project.title %>" class="w-full h-full object-cover">
        <% } else { %>
        <div class="w-full h-full flex items-center justify-center">
          <svg class="w-8 h-8 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
          </svg>
        </div>
        <% } %>
      </div>

      <div class="flex-1 min-w-0">
        <div class="flex items-start gap-2 flex-wrap mb-1">
          <h1 class="text-lg font-bold text-neutral-900 dark:text-white"><%= project.title %></h1>
          <span class="px-2 py-0.5 text-xs bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded-full font-medium">
            <%= project.project_type %>
          </span>
          <% if (isAnyInstallationBlocked) { %>
          <span class="px-2 py-0.5 text-xs bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 rounded-full font-medium">Disabled</span>
          <% } %>
        </div>
        <p class="text-sm text-neutral-600 dark:text-neutral-300 line-clamp-2"><%= project.description %></p>

        <div class="flex items-center gap-4 mt-2 text-xs text-neutral-500">
          <span class="flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2H3V4z"></path>
            </svg>
            <%= (project.downloads || 0).toLocaleString() %>
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
            </svg>
            <%= (project.followers || 0).toLocaleString() %>
          </span>
        </div>

        <% if (project.categories?.length > 0) { %>
        <div class="flex flex-wrap gap-1.5 mt-2">
          <% project.categories.slice(0, 4).forEach(cat => { %>
          <span class="px-2 py-0.5 text-xs bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 rounded-full"><%= cat %></span>
          <% }); %>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="sticky top-[97px] z-20 bg-white dark:bg-[#141414] border-b border-neutral-200 dark:border-white/5">
    <div class="flex">
      <button class="tab-btn flex-1 py-3 text-sm font-medium text-emerald-600 dark:text-emerald-400 border-b-2 border-emerald-500" data-tab="versions">Versions</button>
      <button class="tab-btn flex-1 py-3 text-sm font-medium text-neutral-500 border-b-2 border-transparent" data-tab="description">About</button>
      <button class="tab-btn flex-1 py-3 text-sm font-medium text-neutral-500 border-b-2 border-transparent" data-tab="details">Details</button>
    </div>
  </div>

  <!-- Tab: Versions -->
  <div id="tab-versions" class="tab-content px-4 pt-4">
    <% if (versions && versions.length > 0) { %>
    <div class="space-y-2.5" id="versions-list">
      <% versions.slice(0, 10).forEach(version => { %>
      <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-4">
        <div class="flex items-start justify-between mb-2">
          <div>
            <p class="font-medium text-sm text-neutral-900 dark:text-white"><%= version.name %></p>
            <p class="text-xs text-neutral-500 font-mono mt-0.5"><%= version.version_number %></p>
          </div>
          <span class="px-2 py-0.5 text-xs bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded-full font-medium">
            <%= version.version_type %>
          </span>
        </div>

        <div class="text-xs text-neutral-500 space-y-1 mb-3">
          <% if (version.game_versions?.length > 0) { %>
          <p>Minecraft: <span class="text-neutral-700 dark:text-neutral-300"><%= version.game_versions.slice(0, 3).join(', ') %><%= version.game_versions.length > 3 ? ` +${version.game_versions.length - 3}` : '' %></span></p>
          <% } %>
          <% if (version.loaders?.length > 0) { %>
          <p>Loaders: <span class="text-neutral-700 dark:text-neutral-300"><%= version.loaders.join(', ') %></span></p>
          <% } %>
          <% if (version.date_published) { %>
          <p><%= new Date(version.date_published).toLocaleDateString() %></p>
          <% } %>
        </div>

        <% if (!isAnyInstallationBlocked) { %>
        <button onclick="installVersion('<%= project.id %>', '<%= version.id %>')"
          class="w-full py-2.5 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white rounded-lg text-sm font-medium transition-colors install-button">
          Install
        </button>
        <% } else { %>
        <div class="w-full py-2.5 bg-neutral-100 dark:bg-neutral-800 text-neutral-400 rounded-lg text-sm font-medium text-center">
          Installation disabled
        </div>
        <% } %>
      </div>
      <% }); %>
    </div>

    <% if (versions.length > 10) { %>
    <button id="show-more-versions" class="w-full mt-3 py-3 text-sm text-neutral-500 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-800 rounded-xl">
      Show <%= versions.length - 10 %> more versions
    </button>
    <% } %>
    <% } else { %>
    <p class="text-center py-8 text-sm text-neutral-500">No versions available</p>
    <% } %>
  </div>

  <!-- Tab: Description -->
  <div id="tab-description" class="tab-content px-4 pt-4 hidden">
    <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-4 overflow-hidden">
      <% if (project.body) { %>
      <div id="mobile-project-body" class="mobile-md-content text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed overflow-x-hidden break-words"><%= project.body %></div>
      <% } else { %>
      <p class="text-neutral-600 dark:text-neutral-300 text-sm leading-relaxed"><%= project.description %></p>
      <% } %>
    </div>
  </div>

  <!-- Tab: Details -->
  <div id="tab-details" class="tab-content px-4 pt-4 hidden">
    <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl divide-y divide-neutral-100 dark:divide-neutral-800 overflow-hidden">
      <% if (project.license?.name) { %>
      <div class="flex items-center justify-between px-4 py-3">
        <span class="text-sm text-neutral-500">License</span>
        <span class="text-sm font-medium text-neutral-900 dark:text-white"><%= project.license.name %></span>
      </div>
      <% } %>
      <% if (project.client_side) { %>
      <div class="flex items-center justify-between px-4 py-3">
        <span class="text-sm text-neutral-500">Client side</span>
        <span class="text-sm font-medium text-neutral-900 dark:text-white capitalize"><%= project.client_side %></span>
      </div>
      <% } %>
      <% if (project.server_side) { %>
      <div class="flex items-center justify-between px-4 py-3">
        <span class="text-sm text-neutral-500">Server side</span>
        <span class="text-sm font-medium text-neutral-900 dark:text-white capitalize"><%= project.server_side %></span>
      </div>
      <% } %>
      <% if (project.published) { %>
      <div class="flex items-center justify-between px-4 py-3">
        <span class="text-sm text-neutral-500">Published</span>
        <span class="text-sm text-neutral-900 dark:text-white"><%= new Date(project.published).toLocaleDateString() %></span>
      </div>
      <% } %>
      <% if (project.updated) { %>
      <div class="flex items-center justify-between px-4 py-3">
        <span class="text-sm text-neutral-500">Updated</span>
        <span class="text-sm text-neutral-900 dark:text-white"><%= new Date(project.updated).toLocaleDateString() %></span>
      </div>
      <% } %>
    </div>

    <% const hasLinks = project.source_url || project.issues_url || project.wiki_url || project.discord_url; %>
    <% if (hasLinks) { %>
    <div class="mt-3 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl divide-y divide-neutral-100 dark:divide-neutral-800">
      <% if (project.source_url) { %>
      <a href="<%= project.source_url %>" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between px-4 py-3">
        <span class="text-sm text-neutral-700 dark:text-neutral-300">Source Code</span>
        <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
      <% } %>
      <% if (project.issues_url) { %>
      <a href="<%= project.issues_url %>" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between px-4 py-3">
        <span class="text-sm text-neutral-700 dark:text-neutral-300">Issues</span>
        <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
      <% } %>
      <% if (project.wiki_url) { %>
      <a href="<%= project.wiki_url %>" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between px-4 py-3">
        <span class="text-sm text-neutral-700 dark:text-neutral-300">Wiki</span>
        <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
      <% } %>
      <% if (project.discord_url) { %>
      <a href="<%= project.discord_url %>" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between px-4 py-3">
        <span class="text-sm text-neutral-700 dark:text-neutral-300">Discord</span>
        <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
      <% } %>
    </div>
    <% } %>

    <p class="text-center text-xs text-neutral-400 mt-4 pb-2">
      Modrinth store by <a href="https://github.com/g-flame-oss" target="_blank" class="text-emerald-500">g-flame</a> &bull;
      Panel by <a href="https://github.com/AirlinkLabs" target="_blank" class="text-emerald-500">AirlinkLabs</a>
    </p>
  </div>
</main>

<!-- Fixed bottom install bar -->
<% if (!isAnyInstallationBlocked) { %>
<div class="fixed bottom-16 left-0 right-0 z-30 px-4 pb-2 bg-white/90 dark:bg-[#141414]/90 backdrop-blur-sm border-t border-neutral-200 dark:border-white/5 pt-3">
  <button onclick="openInstallLatest()"
    class="w-full py-3 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white rounded-xl text-sm font-semibold transition-colors">
    Install Latest Version
  </button>
</div>
<% } else { %>
<div class="fixed bottom-16 left-0 right-0 z-30 px-4 pb-2 bg-white/90 dark:bg-[#141414]/90 backdrop-blur-sm border-t border-neutral-200 dark:border-white/5 pt-3">
  <div class="w-full py-3 bg-neutral-100 dark:bg-neutral-800 text-neutral-400 rounded-xl text-sm font-semibold text-center">
    Installation Disabled
  </div>
</div>
<% } %>

<!-- Server picker sheet -->
<div id="serverSheet" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/40" onclick="closeServerSheet()"></div>
  <div class="absolute bottom-0 left-0 right-0 bg-white dark:bg-[#1a1a1a] rounded-t-2xl max-h-[70vh] flex flex-col">
    <div class="flex items-center justify-between px-5 pt-5 pb-4 border-b border-neutral-200 dark:border-white/5">
      <h3 class="font-semibold text-neutral-900 dark:text-white">Choose Server</h3>
      <button onclick="closeServerSheet()" class="p-2 text-neutral-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <div id="server-sheet-list" class="flex-1 overflow-y-auto px-4 py-3 space-y-2"></div>
    <div class="px-4 pb-6 pt-3 border-t border-neutral-200 dark:border-white/5">
      <button id="confirmInstall" onclick="confirmInstall()"
        class="w-full py-3 bg-emerald-600 text-white rounded-xl text-sm font-semibold disabled:opacity-40 transition-colors">
        Install
      </button>
    </div>
  </div>
</div>

<!-- Progress modal -->
<%- include('progress') %>

<!-- Toast -->
<div id="toast" class="fixed top-[110px] left-4 right-4 z-50 hidden">
  <div class="bg-neutral-900 border border-neutral-700 rounded-xl shadow-lg p-3">
    <div class="flex items-center gap-2">
      <div id="toastIcon" class="flex-shrink-0"></div>
      <div class="flex-1">
        <div id="toastTitle" class="font-medium text-white text-sm"></div>
        <div id="toastMessage" class="text-neutral-400 text-xs"></div>
      </div>
      <button onclick="hideToast()" class="text-neutral-400 p-1">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .no-scrollbar { overflow: auto; -ms-overflow-style: none; scrollbar-width: none; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .tab-btn.active { color: rgb(16 185 129); border-bottom-color: rgb(16 185 129); }
  .mobile-md-content { overflow-x: hidden; word-break: break-word; }
  .mobile-md-content h1, .mobile-md-content h2, .mobile-md-content h3, .mobile-md-content h4 { color: #171717; font-weight: 600; margin-top: 1.25em; margin-bottom: 0.4em; }
  @media (prefers-color-scheme: dark) {
    .mobile-md-content h1, .mobile-md-content h2, .mobile-md-content h3, .mobile-md-content h4 { color: #fff; }
  }
  .dark .mobile-md-content h1, .dark .mobile-md-content h2, .dark .mobile-md-content h3, .dark .mobile-md-content h4 { color: #fff; }
  .mobile-md-content h1 { font-size: 1.25rem; }
  .mobile-md-content h2 { font-size: 1.1rem; }
  .mobile-md-content h3 { font-size: 1rem; }
  .mobile-md-content p { margin-bottom: 0.75em; line-height: 1.6; }
  .mobile-md-content ul, .mobile-md-content ol { margin-left: 1.25em; margin-bottom: 0.75em; }
  .mobile-md-content li { margin-bottom: 0.3em; }
  .mobile-md-content code { background: #f3f4f6; color: #d97706; padding: 0.1em 0.35em; border-radius: 0.25em; font-size: 0.8em; font-family: monospace; }
  .dark .mobile-md-content code { background: #262626; color: #fbbf24; }
  .mobile-md-content pre { background: #f9fafb; border: 1px solid #e5e7eb; padding: 0.75em 1em; border-radius: 0.5em; overflow-x: auto; margin: 0.75em 0; max-width: 100%; }
  .dark .mobile-md-content pre { background: #171717; border-color: #262626; }
  .mobile-md-content pre code { background: transparent; color: #374151; padding: 0; }
  .dark .mobile-md-content pre code { color: #d4d4d4; }
  .mobile-md-content a { color: #059669; text-decoration: underline; }
  .mobile-md-content blockquote { border-left: 3px solid #d1d5db; padding-left: 0.75em; margin: 0.75em 0; color: #6b7280; font-style: italic; }
  .dark .mobile-md-content blockquote { border-left-color: #404040; color: #737373; }
  .mobile-md-content img { max-width: 100%; border-radius: 0.5em; margin: 0.75em 0; height: auto; }
  .mobile-md-content table { width: 100%; border-collapse: collapse; margin: 0.75em 0; font-size: 0.8em; display: block; overflow-x: auto; }
  .mobile-md-content th, .mobile-md-content td { padding: 0.4em 0.6em; border: 1px solid #e5e7eb; }
  .dark .mobile-md-content th, .dark .mobile-md-content td { border-color: #404040; }
  .mobile-md-content th { background: #f3f4f6; font-weight: 600; }
  .dark .mobile-md-content th { background: #262626; }
</style>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
  const ALL_VERSIONS = <%- JSON.stringify(versions || []) %>;
  const PROJECT_ID = '<%= project.id %>';
  let selectedServerId = null;
  let pendingVersionId = null;

  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('text-emerald-600', 'dark:text-emerald-400', 'border-emerald-500');
        b.classList.add('text-neutral-500', 'border-transparent');
      });
      document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));

      btn.classList.add('text-emerald-600', 'dark:text-emerald-400', 'border-emerald-500');
      btn.classList.remove('text-neutral-500', 'border-transparent');
      document.getElementById('tab-' + btn.dataset.tab).classList.remove('hidden');
    });
  });

  document.addEventListener('DOMContentLoaded', () => {
    const bodyEl = document.getElementById('mobile-project-body');
    if (bodyEl && typeof marked !== 'undefined') {
      const md = bodyEl.textContent.trim();
      if (md) bodyEl.innerHTML = marked.parse(md);
    }
  });

  // Show more versions
  const showMoreBtn = document.getElementById('show-more-versions');
  if (showMoreBtn) {
    showMoreBtn.addEventListener('click', () => {
      const list = document.getElementById('versions-list');
      const remaining = ALL_VERSIONS.slice(10);
      remaining.forEach(v => {
        const blocked = <%- isAnyInstallationBlocked ? 'true' : 'false' %>;
        list.insertAdjacentHTML('beforeend', `
          <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-4">
            <div class="flex items-start justify-between mb-2">
              <div>
                <p class="font-medium text-sm text-neutral-900 dark:text-white">${v.name}</p>
                <p class="text-xs text-neutral-500 font-mono mt-0.5">${v.version_number}</p>
              </div>
              <span class="px-2 py-0.5 text-xs bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded-full">${v.version_type}</span>
            </div>
            ${!blocked ? `<button onclick="installVersion('${PROJECT_ID}', '${v.id}')" class="w-full py-2.5 bg-emerald-600 text-white rounded-lg text-sm font-medium install-button">Install</button>` : `<div class="w-full py-2.5 bg-neutral-100 dark:bg-neutral-800 text-neutral-400 rounded-lg text-sm text-center">Installation disabled</div>`}
          </div>
        `);
      });
      showMoreBtn.remove();
    });
  }

  function openInstallLatest() {
    if (ALL_VERSIONS.length === 0) return;
    installVersion(PROJECT_ID, ALL_VERSIONS[0].id);
  }

  async function installVersion(projectId, versionId) {
    pendingVersionId = versionId;
    selectedServerId = null;

    try {
      const res = await fetch('/modrinth/api/servers');
      const data = await res.json();

      if (!data.success || !data.data?.length) {
        showToast('No servers available', 'error');
        return;
      }

      const list = document.getElementById('server-sheet-list');
      list.innerHTML = '';

      data.data.forEach(server => {
        const div = document.createElement('div');
        div.className = 'server-option flex items-center gap-3 p-3.5 rounded-xl border border-neutral-200 dark:border-neutral-800 cursor-pointer transition-colors';
        div.dataset.serverId = server.id;
        div.innerHTML = `
          <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"></path>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-neutral-900 dark:text-white truncate">${server.name}</p>
            <p class="text-xs text-neutral-500 capitalize">${server.status}</p>
          </div>
          <div class="w-5 h-5 rounded-full border-2 border-neutral-300 dark:border-neutral-600 flex-shrink-0 check-circle"></div>
        `;
        div.addEventListener('click', () => selectServer(server.id, div));
        list.appendChild(div);
      });

      document.getElementById('serverSheet').classList.remove('hidden');
    } catch {
      showToast('Failed to load servers', 'error');
    }
  }

  function selectServer(id, el) {
    selectedServerId = id;
    document.querySelectorAll('.server-option').forEach(d => {
      d.classList.remove('border-emerald-500', 'bg-emerald-50', 'dark:bg-emerald-900/10');
      d.querySelector('.check-circle').className = 'w-5 h-5 rounded-full border-2 border-neutral-300 dark:border-neutral-600 flex-shrink-0 check-circle';
    });
    el.classList.add('border-emerald-500', 'bg-emerald-50', 'dark:bg-emerald-900/10');
    el.querySelector('.check-circle').className = 'w-5 h-5 rounded-full bg-emerald-500 border-2 border-emerald-500 flex-shrink-0 check-circle flex items-center justify-center';
  }

  function closeServerSheet() {
    document.getElementById('serverSheet').classList.add('hidden');
    selectedServerId = null;
    pendingVersionId = null;
  }

  async function confirmInstall() {
    if (!selectedServerId || !pendingVersionId) {
      showToast('Select a server first', 'warning');
      return;
    }

    const btn = document.getElementById('confirmInstall');
    btn.textContent = 'Installing...';
    btn.disabled = true;

    try {
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
      const res = await fetch('/modrinth/api/install', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(csrfToken ? { 'X-CSRF-Token': csrfToken } : {}),
        },
        body: JSON.stringify({ serverId: selectedServerId, projectId: PROJECT_ID, versionId: pendingVersionId }),
      });

      const data = await res.json();
      closeServerSheet();

      if (data.success) {
        showToast('Installation started', 'success');
      } else {
        showToast(data.error || 'Install failed', 'error');
      }
    } catch {
      showToast('Request failed', 'error');
    } finally {
      btn.textContent = 'Install';
      btn.disabled = false;
    }
  }

  function showToast(message, type = 'info', duration = 4000) {
    const svgs = {
      success: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>',
      error:   '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>',
      warning: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path></svg>',
      info:    '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
    };
    const colors = { success: 'emerald', error: 'red', warning: 'amber', info: 'blue' };
    const labels = { success: 'Done', error: 'Error', warning: 'Warning', info: 'Info' };
    const color = colors[type] || 'blue';
    document.getElementById('toastIcon').innerHTML = `<div class="w-7 h-7 bg-${color}-600 rounded-full flex items-center justify-center text-white flex-shrink-0">${svgs[type] || svgs.info}</div>`;
    document.getElementById('toastTitle').textContent = labels[type] || 'Info';
    document.getElementById('toastMessage').textContent = message;
    document.getElementById('toast').classList.remove('hidden');
    if (duration > 0) setTimeout(hideToast, duration);
  }

  function hideToast() {
    document.getElementById('toast').classList.add('hidden');
  }
</script>

