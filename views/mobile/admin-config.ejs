<%- include(components.header, { title: title, user: user }) %>

<main class="min-h-screen pb-8">
  <%- include(components.template) %>

  <!-- Top nav -->
  <div class="sticky top-14 z-30 bg-white dark:bg-[#141414] border-b border-neutral-200 dark:border-white/5 px-4 py-2.5 flex items-center justify-between">
    <div class="flex items-center gap-1.5 text-xs text-neutral-500">
      <a href="/modrinth" class="text-emerald-600 dark:text-emerald-400">Store</a>
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
      </svg>
      <span>Admin Config</span>
    </div>
    <button onclick="openProgressModal()" class="flex items-center gap-1.5 px-3 py-1.5 bg-emerald-600 text-white rounded-lg text-xs font-medium">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
      </svg>
      Status
    </button>
  </div>

  <div class="px-4 py-4 space-y-4">

    <!-- File status -->
    <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-4">
      <p class="text-sm font-medium text-neutral-900 dark:text-white mb-3">Settings File</p>
      <div id="file-status-content" class="text-xs text-neutral-500">Loading...</div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-2">
      <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-3 text-center">
        <div class="text-lg font-bold text-emerald-600 dark:text-emerald-400" id="stat-total-installs">—</div>
        <div class="text-xs text-neutral-500 mt-0.5">Installs</div>
      </div>
      <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-3 text-center">
        <div class="text-lg font-bold text-blue-600 dark:text-blue-400" id="stat-projects">—</div>
        <div class="text-xs text-neutral-500 mt-0.5">Projects</div>
      </div>
      <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-3 text-center">
        <div class="text-lg font-bold text-red-500" id="stat-blocked">—</div>
        <div class="text-xs text-neutral-500 mt-0.5">Blocked</div>
      </div>
    </div>

    <!-- JSON Editor -->
    <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-4">
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm font-medium text-neutral-900 dark:text-white">Configuration</p>
        <div class="flex gap-2">
          <button onclick="loadCurrentSettings()" class="px-3 py-1.5 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 rounded-lg text-xs font-medium">
            Reload
          </button>
          <button onclick="saveSettings()" id="saveBtn" class="px-3 py-1.5 bg-emerald-600 text-white rounded-lg text-xs font-medium">
            Save
          </button>
        </div>
      </div>

      <div id="save-status" class="hidden mb-3 p-3 rounded-lg text-xs"></div>

      <textarea id="settingsEditor"
        class="w-full h-64 px-3 py-3 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-xl text-xs font-mono text-neutral-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 resize-none"
        placeholder="Loading settings..."></textarea>

      <p class="text-xs text-neutral-400 mt-2">Edit JSON directly. Press Save when done.</p>
    </div>

    <!-- Reference -->
    <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-4">
      <p class="text-sm font-medium text-neutral-900 dark:text-white mb-3">Field Reference</p>
      <div class="space-y-2 text-xs">
        <div class="flex gap-2">
          <code class="text-emerald-600 dark:text-emerald-400 font-mono flex-shrink-0">modrinthInstallationWarning</code>
          <span class="text-neutral-500">boolean — show warning banner</span>
        </div>
        <div class="flex gap-2">
          <code class="text-emerald-600 dark:text-emerald-400 font-mono flex-shrink-0">warningTitle</code>
          <span class="text-neutral-500">string — banner title text</span>
        </div>
        <div class="flex gap-2">
          <code class="text-emerald-600 dark:text-emerald-400 font-mono flex-shrink-0">warningMessage</code>
          <span class="text-neutral-500">string — banner body text</span>
        </div>
        <div class="flex gap-2">
          <code class="text-emerald-600 dark:text-emerald-400 font-mono flex-shrink-0">disabledProjectTypes</code>
          <span class="text-neutral-500">string[] — e.g. ["mod", "shader"]</span>
        </div>
        <div class="flex gap-2">
          <code class="text-emerald-600 dark:text-emerald-400 font-mono flex-shrink-0">blockedProjects</code>
          <span class="text-neutral-500">string[] — project IDs to block</span>
        </div>
      </div>
    </div>

    <!-- Cache -->
    <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-4">
      <p class="text-sm font-medium text-neutral-900 dark:text-white mb-1">Cache</p>
      <p class="text-xs text-neutral-500 mb-3">Clears all cached Modrinth API responses.</p>
      <button onclick="clearCache()" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-xs font-medium transition-colors">
        Clear Cache
      </button>
    </div>

  </div>
</main>

<%- include('progress') %>

<div id="toast" class="fixed top-[110px] left-4 right-4 z-50 hidden">
  <div class="bg-neutral-900 border border-neutral-700 rounded-xl shadow-lg p-3">
    <div class="flex items-center gap-2">
      <div id="toastIcon" class="flex-shrink-0"></div>
      <div class="flex-1">
        <div id="toastTitle" class="font-medium text-white text-sm"></div>
        <div id="toastMessage" class="text-neutral-400 text-xs"></div>
      </div>
      <button onclick="hideToast()" class="text-neutral-400 p-1">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  async function loadCurrentSettings() {
    try {
      const res = await fetch('/modrinth/api/config', { credentials: 'include' });
      const data = await res.json();
      if (data.success && data.data) {
        document.getElementById('settingsEditor').value = JSON.stringify(data.data, null, 2);
        showToast('Settings reloaded', 'success');
      } else {
        showToast('Failed to load settings', 'error');
      }
    } catch {
      showToast('Failed to load settings', 'error');
    }
  }

  async function loadFileStatus() {
    try {
      const res = await fetch('/modrinth/api/file-status');
      const data = await res.json();
      const el = document.getElementById('file-status-content');
      if (data.success && data.data.exists) {
        el.innerHTML = `<span class="text-emerald-500">File exists</span> &bull; ${data.data.size} bytes &bull; Modified ${new Date(data.data.lastModified).toLocaleString()}`;
      } else {
        el.innerHTML = '<span class="text-amber-500">File not created yet</span> — will be created on first save';
      }
    } catch {
      document.getElementById('file-status-content').textContent = 'Could not load file status';
    }
  }

  async function loadStatistics() {
    try {
      const res = await fetch('/modrinth/api/statistics');
      const data = await res.json();
      if (data.success) {
        document.getElementById('stat-total-installs').textContent = data.data.totalInstallations;
        document.getElementById('stat-projects').textContent = data.data.activeProjects;
        document.getElementById('stat-blocked').textContent = data.data.blockedInstallations;
      }
    } catch {}
  }

  async function saveSettings() {
    const editor = document.getElementById('settingsEditor');
    const btn = document.getElementById('saveBtn');
    const status = document.getElementById('save-status');

    let parsed;
    try {
      parsed = JSON.parse(editor.value);
    } catch {
      status.className = 'mb-3 p-3 rounded-lg text-xs bg-red-500/10 text-red-400 border border-red-500/20';
      status.textContent = 'Invalid JSON — check syntax';
      status.classList.remove('hidden');
      return;
    }

    btn.textContent = 'Saving...';
    btn.disabled = true;

    try {
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
      const res = await fetch('/modrinth/admin/config', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(csrfToken ? { 'X-CSRF-Token': csrfToken } : {}),
        },
        body: JSON.stringify(parsed),
      });

      const data = await res.json();

      if (data.success) {
        status.className = 'mb-3 p-3 rounded-lg text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
        status.textContent = 'Settings saved successfully';
        status.classList.remove('hidden');
        loadFileStatus();
        showToast('Settings saved', 'success');
        setTimeout(() => status.classList.add('hidden'), 4000);
      } else {
        status.className = 'mb-3 p-3 rounded-lg text-xs bg-red-500/10 text-red-400 border border-red-500/20';
        status.textContent = data.error || 'Save failed';
        status.classList.remove('hidden');
      }
    } catch {
      showToast('Request failed', 'error');
    } finally {
      btn.textContent = 'Save';
      btn.disabled = false;
    }
  }

  async function clearCache() {
    try {
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
      const res = await fetch('/modrinth/api/cache/clear', {
        method: 'POST',
        headers: { ...(csrfToken ? { 'X-CSRF-Token': csrfToken } : {}) },
      });
      const data = await res.json();
      showToast(data.success ? 'Cache cleared' : (data.error || 'Failed'), data.success ? 'success' : 'error');
    } catch {
      showToast('Request failed', 'error');
    }
  }

  function showToast(message, type = 'info', duration = 4000) {
    const svgs = {
      success: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>',
      error:   '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>',
      warning: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path></svg>',
      info:    '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
    };
    const colors = { success: 'emerald', error: 'red', warning: 'amber', info: 'blue' };
    const labels = { success: 'Done', error: 'Error', warning: 'Warning', info: 'Info' };
    const color = colors[type] || 'blue';
    document.getElementById('toastIcon').innerHTML = `<div class="w-7 h-7 bg-${color}-600 rounded-full flex items-center justify-center text-white flex-shrink-0">${svgs[type] || svgs.info}</div>`;
    document.getElementById('toastTitle').textContent = labels[type] || 'Info';
    document.getElementById('toastMessage').textContent = message;
    document.getElementById('toast').classList.remove('hidden');
    if (duration > 0) setTimeout(hideToast, duration);
  }

  function hideToast() {
    document.getElementById('toast').classList.add('hidden');
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadCurrentSettings();
    loadFileStatus();
    loadStatistics();
  });
</script>

<%- include(components.footer) %>
