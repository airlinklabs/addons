<div id="createBackupModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-end justify-center">
  <div class="bg-[#111] border-t border-neutral-800 rounded-t-2xl w-full max-w-lg max-h-[90vh] flex flex-col">
    <div class="w-10 h-1 bg-neutral-700 rounded-full mx-auto mt-3 flex-shrink-0"></div>
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-800 flex-shrink-0">
      <h2 class="text-sm font-semibold text-white">Create backup</h2>
      <button onclick="hideModal('createBackupModal')" class="text-neutral-600 p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="p-5 overflow-y-auto flex-1 space-y-4">
      <div>
        <label class="block text-xs font-medium text-neutral-400 mb-1.5">Backup name <span class="text-red-400">*</span></label>
        <input type="text" id="backupName" maxlength="100" placeholder="e.g. Pre-update snapshot"
          class="w-full px-3.5 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-sm text-white placeholder-neutral-600 focus:outline-none">
      </div>

      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="useEncryption" onchange="toggleEncryption()"
          class="w-4 h-4 rounded bg-neutral-800 border-neutral-700 text-emerald-600">
        <span class="text-sm text-neutral-300">Encrypt with password</span>
      </label>

      <div id="encryptionFields" class="hidden space-y-3 pl-6 border-l-2 border-neutral-800">
        <div>
          <label class="block text-xs font-medium text-neutral-400 mb-1.5">Password <span class="text-red-400">*</span></label>
          <input type="password" id="backupPassword" placeholder="Strong password"
            class="w-full px-3.5 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-sm text-white placeholder-neutral-600 focus:outline-none">
        </div>
        <div>
          <label class="block text-xs font-medium text-neutral-400 mb-1.5">Hint <span class="text-neutral-600">(optional)</span></label>
          <input type="text" id="passwordHint" maxlength="200" placeholder="Memory aid"
            class="w-full px-3.5 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-sm text-white placeholder-neutral-600 focus:outline-none">
        </div>
      </div>

      <div class="bg-amber-500/5 border border-amber-500/15 rounded-xl p-3.5">
        <p class="text-xs text-amber-400/80">May take 5–15 minutes. Keep this page open.</p>
      </div>
    </div>

    <div class="flex gap-3 px-5 py-4 pb-8 border-t border-neutral-800 flex-shrink-0">
      <button onclick="hideModal('createBackupModal')"
        class="flex-1 py-3 text-sm text-neutral-400 bg-neutral-800 rounded-xl transition-colors">Cancel</button>
      <button id="createBackupBtn" onclick="handleCreateBackup()"
        class="flex-1 py-3 text-sm text-white bg-emerald-600 rounded-xl transition-colors font-medium">Create backup</button>
    </div>
  </div>
</div>

<script>
function toggleEncryption() {
  const on = document.getElementById('useEncryption').checked;
  document.getElementById('encryptionFields').classList.toggle('hidden', !on);
  if (!on) { document.getElementById('backupPassword').value = ''; document.getElementById('passwordHint').value = ''; }
}

async function handleCreateBackup() {
  const name = document.getElementById('backupName').value.trim();
  const encrypt = document.getElementById('useEncryption').checked;
  const password = encrypt ? document.getElementById('backupPassword').value : undefined;
  const hint = encrypt ? document.getElementById('passwordHint').value.trim() : undefined;
  if (!name) { showToast('Backup name is required', 'error'); return; }
  if (encrypt && !password) { showToast('Password required', 'error'); return; }
  const btn = document.getElementById('createBackupBtn');
  btn.disabled = true; btn.textContent = 'Creating…';
  hideModal('createBackupModal');
  showToast('Backup started', 'info', 0);
  try {
    const { success, error } = await fetch('/parachute/api/backup/create', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ serverUUID: currentServerUUID, name, password, passwordHint: hint }),
    }).then(r => r.json());
    if (success) { showToast('Backup created', 'success'); document.getElementById('backupName').value = ''; document.getElementById('useEncryption').checked = false; document.getElementById('encryptionFields').classList.add('hidden'); loadBackups(); }
    else showToast(error || 'Failed to create backup', 'error', 8000);
  } catch { showToast('Network error', 'error', 8000); }
  finally { btn.disabled = false; btn.textContent = 'Create backup'; }
}
</script>
