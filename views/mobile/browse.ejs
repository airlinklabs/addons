<%- include(components.header, { title: title, user: user }) %>

<main class="min-h-screen">
  <%- include(components.template) %>

  <div class="pb-20">
    <% const hasDisabledTypes = modrinthSettings?.disabledProjectTypes?.length > 0;
       const hasBlockedProjects = modrinthSettings?.blockedProjects?.length > 0;
       const shouldShowWarning = modrinthSettings?.modrinthInstallationWarning && (hasDisabledTypes || hasBlockedProjects); %>

    <% if (shouldShowWarning) { %>
    <div class="bg-amber-500/10 border-b border-amber-500/20 px-4 py-3">
      <div class="flex items-start gap-2">
        <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
        </svg>
        <div>
          <p class="font-medium text-amber-400 text-sm"><%= modrinthSettings.warningTitle %></p>
          <p class="text-amber-200 text-xs mt-0.5"><%= modrinthSettings.warningMessage %></p>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Search bar -->
    <div class="px-4 pt-4 pb-3 bg-white dark:bg-[#141414] sticky top-14 z-30 border-b border-neutral-200 dark:border-white/5">
      <form method="GET" action="/modrinth">
        <div class="flex gap-2 mb-3">
          <div class="flex-1 relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <input type="text" name="q" value="<%= query %>" placeholder="Search Modrinth..." autocomplete="off"
              class="w-full pl-9 pr-4 py-2.5 bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-xl text-neutral-900 dark:text-white text-sm placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <button type="submit" class="px-4 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-sm font-medium transition-colors min-w-[56px]">
            Go
          </button>
        </div>

        <!-- Type filter chips -->
        <div class="flex gap-2 overflow-x-auto no-scrollbar">
          <% const typeFilters = [
            { value: 'all', label: 'All' },
            { value: 'mod', label: 'Mods' },
            { value: 'modpack', label: 'Modpacks' },
            { value: 'resourcepack', label: 'Resources' },
            { value: 'shader', label: 'Shaders' },
            { value: 'plugin', label: 'Plugins' },
            { value: 'datapack', label: 'Datapacks' },
          ];
          typeFilters.forEach(f => {
            const isDisabled = hasDisabledTypes && modrinthSettings.disabledProjectTypes.includes(f.value);
            const isActive = type === f.value;
          %>
          <button type="submit" name="type" value="<%= f.value %>"
            class="flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-medium transition-colors <%= isActive ? 'bg-emerald-600 text-white' : 'bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-300' %> <%= isDisabled ? 'opacity-40' : '' %>"
            <%= isDisabled ? 'disabled' : '' %>>
            <%= f.label %><%= isDisabled ? ' (off)' : '' %>
          </button>
          <% }); %>
        </div>
      </form>
    </div>

    <!-- Results -->
    <div class="px-4 py-4">
      <% if (results?.hits?.length > 0) { %>

      <div class="flex items-center justify-between mb-3">
        <div>
          <% if (query) { %>
          <p class="text-sm font-medium text-neutral-900 dark:text-white">Results for "<span class="text-emerald-500"><%= query %></span>"</p>
          <% } else { %>
          <p class="text-sm font-medium text-neutral-900 dark:text-white">Popular Projects</p>
          <% } %>
          <p class="text-xs text-neutral-500 mt-0.5"><%= results.hits.length %> shown<% if (shouldShowWarning) { %> <span class="text-amber-400">(filtered)</span><% } %></p>
        </div>
        <button onclick="openProgressModal()" class="flex items-center gap-1.5 px-3 py-1.5 bg-emerald-600 text-white rounded-lg text-xs font-medium">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
          </svg>
          Status
        </button>
      </div>

      <!-- Card list -->
      <div class="space-y-2.5">
        <% results.hits.forEach(project => {
          const isProjectTypeDisabled = hasDisabledTypes && modrinthSettings.disabledProjectTypes.includes(project.project_type);
          const isProjectBlocked = hasBlockedProjects && modrinthSettings.blockedProjects.includes(project.project_id);
          const isDisabled = isProjectTypeDisabled || isProjectBlocked;
        %>
        <a href="/modrinth/project/<%= project.project_id %>"
          class="flex items-center gap-3 p-3 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl active:scale-[0.98] transition-transform <%= isDisabled ? 'opacity-50' : '' %>">

          <div class="w-14 h-14 flex-shrink-0 rounded-lg overflow-hidden bg-neutral-100 dark:bg-neutral-800 relative">
            <% if (project.icon_url) { %>
            <img src="<%= project.icon_url %>" alt="<%= project.title %>" class="w-full h-full object-cover" loading="lazy">
            <% } else { %>
            <div class="w-full h-full flex items-center justify-center">
              <svg class="w-7 h-7 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
              </svg>
            </div>
            <% } %>
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-2">
              <p class="font-medium text-sm text-neutral-900 dark:text-white truncate"><%= project.title %></p>
              <span class="flex-shrink-0 px-1.5 py-0.5 text-xs bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded">
                <%= project.project_type %>
              </span>
            </div>
            <p class="text-xs text-neutral-500 mt-0.5 line-clamp-2"><%= project.description %></p>
            <div class="flex items-center gap-3 mt-1.5 text-xs text-neutral-400">
              <span class="flex items-center gap-1">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4z"></path>
                </svg>
                <%= (project.downloads || 0).toLocaleString() %>
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
                </svg>
                <%= (project.follows || 0).toLocaleString() %>
              </span>
              <% if (isDisabled) { %>
              <span class="text-red-400"><%= isProjectTypeDisabled ? 'Type disabled' : 'Blocked' %></span>
              <% } %>
            </div>
          </div>

          <svg class="w-4 h-4 text-neutral-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
        <% }); %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
      <div class="flex justify-center items-center gap-2 mt-5">
        <% if (page > 1) { %>
        <a href="/modrinth?<%= query ? `q=${encodeURIComponent(query)}&type=${type}&` : '' %>page=<%= page - 1 %>"
          class="px-4 py-2 text-sm bg-neutral-100 dark:bg-neutral-800 text-neutral-900 dark:text-white rounded-lg border border-neutral-200 dark:border-neutral-700">
          Prev
        </a>
        <% } %>
        <span class="text-sm text-neutral-500"><%= page %> / <%= totalPages %></span>
        <% if (page < totalPages) { %>
        <a href="/modrinth?<%= query ? `q=${encodeURIComponent(query)}&type=${type}&` : '' %>page=<%= page + 1 %>"
          class="px-4 py-2 text-sm bg-neutral-100 dark:bg-neutral-800 text-neutral-900 dark:text-white rounded-lg border border-neutral-200 dark:border-neutral-700">
          Next
        </a>
        <% } %>
      </div>
      <% } %>

      <% } else if (query) { %>
      <div class="text-center py-16">
        <div class="w-14 h-14 mx-auto mb-4 bg-neutral-100 dark:bg-neutral-800 rounded-full flex items-center justify-center">
          <svg class="w-7 h-7 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <p class="font-medium text-neutral-900 dark:text-white">No results for "<%= query %>"</p>
        <p class="text-sm text-neutral-500 mt-1"><%= shouldShowWarning ? 'Some content is filtered by admin.' : 'Try different terms.' %></p>
        <a href="/modrinth" class="inline-block mt-4 px-5 py-2.5 bg-emerald-600 text-white rounded-xl text-sm font-medium">Browse All</a>
      </div>
      <% } else { %>
      <div class="text-center py-16">
        <div class="w-14 h-14 mx-auto mb-4 bg-neutral-100 dark:bg-neutral-800 rounded-full flex items-center justify-center">
          <svg class="w-7 h-7 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <p class="font-medium text-neutral-900 dark:text-white">Search Modrinth</p>
        <p class="text-sm text-neutral-500 mt-1">Find mods, modpacks, shaders, and more.</p>
      </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('progress') %>

<div id="toast" class="fixed top-16 left-4 right-4 z-50 hidden">
  <div class="bg-neutral-900 border border-neutral-700 rounded-xl shadow-lg p-3">
    <div class="flex items-start gap-2">
      <div id="toastIcon" class="flex-shrink-0"></div>
      <div class="flex-1">
        <div id="toastTitle" class="font-medium text-white text-sm"></div>
        <div id="toastMessage" class="text-neutral-400 text-xs mt-0.5"></div>
      </div>
      <button onclick="hideToast()" class="text-neutral-400 p-1">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .no-scrollbar { overflow: auto; -ms-overflow-style: none; scrollbar-width: none; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script>
  function showToast(message, type = 'info', duration = 4000) {
    const toast = document.getElementById('toast');
    const icon = document.getElementById('toastIcon');
    const title = document.getElementById('toastTitle');
    const messageEl = document.getElementById('toastMessage');

    const configs = {
      success: { icon: '✓', label: 'Success', color: 'emerald' },
      error:   { icon: '✗', label: 'Error',   color: 'red' },
      warning: { icon: '!', label: 'Warning',  color: 'amber' },
      info:    { icon: 'i', label: 'Info',     color: 'blue' },
    };
    const cfg = configs[type] || configs.info;

    icon.innerHTML = `<div class="w-5 h-5 bg-${cfg.color}-600 rounded-full flex items-center justify-center text-white text-xs font-bold">${cfg.icon}</div>`;
    title.textContent = cfg.label;
    messageEl.textContent = message;
    toast.classList.remove('hidden');
    if (duration > 0) setTimeout(hideToast, duration);
  }

  function hideToast() {
    document.getElementById('toast').classList.add('hidden');
  }

  const modrinthSettings = <%- JSON.stringify(modrinthSettings || {}) %>;

  document.querySelector('form')?.addEventListener('submit', function(e) {
    const typeSelect = document.querySelector('select[name="type"]');
    if (!typeSelect) return;
    const selected = typeSelect.value;
    if (selected !== 'all' && modrinthSettings?.disabledProjectTypes?.includes(selected)) {
      e.preventDefault();
      showToast(`${selected} projects are disabled by admin`, 'error');
      typeSelect.value = 'all';
    }
  });
</script>

<%- include(components.footer) %>
