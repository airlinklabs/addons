<%- include(components.header, { title: title, user: user }) %>

<main class="h-screen flex">
  <div class="w-60 h-full flex-shrink-0">
    <%- include(components.template) %>
  </div>

  <div class="flex-1 flex flex-col overflow-hidden pt-16">
    <% const hasDisabledTypes = modrinthSettings?.disabledProjectTypes?.length > 0;
       const hasBlockedProjects = modrinthSettings?.blockedProjects?.length > 0;
       const shouldShowWarning = modrinthSettings?.modrinthInstallationWarning && (hasDisabledTypes || hasBlockedProjects); %>

    <% if (shouldShowWarning) { %>
    <div class="flex-shrink-0 bg-amber-500/10 border-b border-amber-500/20 px-6 py-2.5 flex items-center gap-3">
      <svg class="w-4 h-4 text-amber-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
      </svg>
      <span class="text-amber-400 font-medium text-sm"><%= modrinthSettings.warningTitle %></span>
      <span class="text-amber-300/70 text-sm"><%= modrinthSettings.warningMessage %></span>
      <% if (hasDisabledTypes) { %><span class="text-xs text-amber-300 bg-amber-500/20 px-2 py-0.5 rounded">Disabled: <%= modrinthSettings.disabledProjectTypes.join(', ') %></span><% } %>
      <% if (hasBlockedProjects) { %><span class="text-xs text-amber-300 bg-amber-500/20 px-2 py-0.5 rounded"><%= modrinthSettings.blockedProjects.length %> blocked</span><% } %>
    </div>
    <% } %>

    <div class="flex-shrink-0 border-b border-neutral-800 px-6 py-4">
      <form method="GET" action="/modrinth">
        <div class="flex gap-2.5">
          <div class="relative flex-1">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input type="text" name="q" value="<%= query %>" placeholder="Search mods, plugins, modpacks..." class="w-full pl-10 pr-4 py-2 bg-neutral-800 border border-neutral-700 rounded-lg text-sm text-white placeholder-neutral-500 focus:outline-none focus:border-emerald-500 transition-colors">
          </div>

          <select name="type" class="px-3 py-2 bg-neutral-800 border border-neutral-700 rounded-lg text-sm text-white focus:outline-none focus:border-emerald-500 transition-colors min-w-[130px]">
            <option value="all" <%= type === 'all' ? 'selected' : '' %>>All types</option>
            <% const typeOptions = [
              { value: 'mod', label: 'Mods' },
              { value: 'modpack', label: 'Modpacks' },
              { value: 'resourcepack', label: 'Resource packs' },
              { value: 'shader', label: 'Shaders' },
              { value: 'plugin', label: 'Plugins' },
              { value: 'datapack', label: 'Data packs' }
            ];
            typeOptions.forEach(function(opt) {
              const disabled = hasDisabledTypes && modrinthSettings.disabledProjectTypes.includes(opt.value);
            %>
            <option value="<%= opt.value %>" <%= type === opt.value ? 'selected' : '' %> <%= disabled ? 'disabled' : '' %>><%= opt.label %><%= disabled ? ' (disabled)' : '' %></option>
            <% }); %>
          </select>

          <select id="sortFilter" class="px-3 py-2 bg-neutral-800 border border-neutral-700 rounded-lg text-sm text-white focus:outline-none focus:border-emerald-500 transition-colors min-w-[120px]">
            <option value="relevance">Relevance</option>
            <option value="downloads">Downloads</option>
            <option value="updated">Updated</option>
            <option value="newest">Newest</option>
          </select>

          <button type="submit" class="px-5 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-medium transition-colors">Search</button>
        </div>

        <div class="flex gap-2 mt-3">
          <% ['Technology', 'Adventure', 'Optimization', 'Decoration', 'Magic', 'Food'].forEach(function(filter) { %>
          <button type="button" class="quick-filter px-3 py-1 text-xs bg-neutral-800 hover:bg-emerald-600 text-neutral-400 hover:text-white border border-neutral-700 hover:border-emerald-500 rounded-full transition-colors" data-category="<%= filter.toLowerCase() %>">
            <%= filter %>
          </button>
          <% }); %>
        </div>
      </form>
    </div>

    <div class="flex-1 overflow-y-auto no-scrollbar">
      <div class="px-6 py-5">

        <% if (results && results.hits && results.hits.length > 0) { %>

        <div class="flex items-center justify-between mb-5">
          <div>
            <% if (query) { %>
            <h2 class="text-base font-semibold text-white">Results for "<span class="text-emerald-400"><%= query %></span>"</h2>
            <% } else { %>
            <h2 class="text-base font-semibold text-white">Popular projects</h2>
            <% } %>
            <p class="text-neutral-500 text-xs mt-0.5"><%= results.hits.length %> of <%= results.total_hits.toLocaleString() %><% if (shouldShowWarning) { %> <span class="text-amber-500">(filtered)</span><% } %></p>
          </div>

          <div class="flex items-center gap-2.5">
            <button onclick="openProgressModal()" class="flex items-center gap-2 px-3 py-1.5 bg-neutral-800 hover:bg-neutral-700 text-neutral-300 hover:text-white border border-neutral-700 rounded-lg text-sm transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
              </svg>
              Installations
            </button>
            <div class="flex bg-neutral-800 border border-neutral-700 rounded-lg overflow-hidden">
              <button id="gridViewBtn" class="p-2 bg-emerald-600 text-white">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
              </button>
              <button id="listViewBtn" class="p-2 text-neutral-400 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
              </button>
            </div>
          </div>
        </div>

        <div id="resultsContainer" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          <% results.hits.forEach(function(project) {
            var typeDisabled = hasDisabledTypes && modrinthSettings.disabledProjectTypes.includes(project.project_type);
            var isBlocked = hasBlockedProjects && modrinthSettings.blockedProjects.includes(project.project_id);
            var isDisabled = typeDisabled || isBlocked;
          %>
          <a href="/modrinth/project/<%= project.project_id %>" class="project-card group flex flex-col bg-neutral-900 border border-neutral-800 hover:border-neutral-600 rounded-xl overflow-hidden transition-all duration-200 <%= isDisabled ? 'opacity-50' : '' %>">
            <div class="relative aspect-square bg-neutral-800 overflow-hidden flex-shrink-0">
              <% if (project.icon_url) { %>
              <img src="<%= project.icon_url %>" alt="<%= project.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
              <% } else { %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="w-12 h-12 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
              </div>
              <% } %>
              <div class="absolute top-2 right-2">
                <span class="px-1.5 py-0.5 text-xs font-medium bg-black/60 text-white rounded-md backdrop-blur-sm"><%= project.project_type %></span>
              </div>
              <% if (isDisabled) { %>
              <div class="absolute top-2 left-2">
                <span class="px-1.5 py-0.5 text-xs font-medium bg-red-600/80 text-white rounded-md backdrop-blur-sm"><%= typeDisabled ? 'Disabled' : 'Blocked' %></span>
              </div>
              <% } %>
            </div>

            <div class="p-3 flex flex-col flex-1">
              <h3 class="font-medium text-white text-sm group-hover:text-emerald-400 transition-colors mb-1 truncate"><%= project.title %></h3>
              <p class="text-xs text-neutral-500 mb-3 line-clamp-2 flex-1"><%= project.description %></p>
              <div class="flex items-center justify-between text-xs text-neutral-600">
                <div class="flex items-center gap-2.5">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"></path></svg>
                    <%= (project.downloads || 0).toLocaleString() %>
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg>
                    <%= (project.follows || 0).toLocaleString() %>
                  </span>
                </div>
                <span><%= new Date(project.date_modified).toLocaleDateString() %></span>
              </div>
              <% if (project.categories && project.categories.length > 0) { %>
              <div class="flex flex-wrap gap-1 mt-2.5">
                <% project.categories.slice(0, 3).forEach(function(cat) { %><span class="px-1.5 py-0.5 text-xs bg-neutral-800 text-neutral-500 border border-neutral-700/50 rounded"><%= cat %></span><% }); %>
                <% if (project.categories.length > 3) { %><span class="px-1.5 py-0.5 text-xs bg-neutral-800 text-neutral-600 border border-neutral-700/50 rounded">+<%= project.categories.length - 3 %></span><% } %>
              </div>
              <% } %>
            </div>
          </a>
          <% }); %>
        </div>

        <% if (totalPages > 1) { %>
        <div class="flex justify-center items-center gap-1.5 mt-8">
          <% if (page > 1) { %><a href="/modrinth?<%= query ? 'q=' + encodeURIComponent(query) + '&type=' + type + '&' : '' %>page=<%= page - 1 %>" class="px-3 py-1.5 text-sm bg-neutral-800 text-neutral-300 border border-neutral-700 rounded-lg hover:bg-neutral-700 hover:text-white transition-colors">Prev</a><% } %>
          <% var startPage = Math.max(1, page - 2); var endPage = Math.min(totalPages, page + 2);
          for (var i = startPage; i <= endPage; i++) { %>
            <% if (i === page) { %><span class="px-3 py-1.5 text-sm bg-emerald-600 text-white rounded-lg font-medium"><%= i %></span>
            <% } else { %><a href="/modrinth?<%= query ? 'q=' + encodeURIComponent(query) + '&type=' + type + '&' : '' %>page=<%= i %>" class="px-3 py-1.5 text-sm bg-neutral-800 text-neutral-300 border border-neutral-700 rounded-lg hover:bg-neutral-700 hover:text-white transition-colors"><%= i %></a><% } %>
          <% } %>
          <% if (page < totalPages) { %><a href="/modrinth?<%= query ? 'q=' + encodeURIComponent(query) + '&type=' + type + '&' : '' %>page=<%= page + 1 %>" class="px-3 py-1.5 text-sm bg-neutral-800 text-neutral-300 border border-neutral-700 rounded-lg hover:bg-neutral-700 hover:text-white transition-colors">Next</a><% } %>
        </div>
        <% } %>

        <% } else if (query) { %>
        <div class="text-center py-16">
          <div class="w-14 h-14 mx-auto mb-4 bg-neutral-800 border border-neutral-700 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-white mb-2">No results for "<%= query %>"</h3>
          <p class="text-neutral-500 text-sm mb-5"><% if (shouldShowWarning) { %>Some types may be filtered.<% } else { %>Try different search terms.<% } %></p>
          <button onclick="document.querySelector('input[name=q]').value=''; document.querySelector('form').submit();" class="px-5 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-medium transition-colors">Browse all</button>
        </div>
        <% } %>

        <div class="mt-10 pt-5 border-t border-neutral-800 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-neutral-600">
          <div class="flex items-center gap-1.5">
            <span>Modrinth store by</span>
            <a href="https://github.com/g-flame-oss" target="_blank" class="text-neutral-400 hover:text-white transition-colors">g-flame</a>
            <span>•</span>
            <span>Panel by</span>
            <a href="https://github.com/AirlinkLabs" target="_blank" class="text-neutral-400 hover:text-white transition-colors">AirlinkLabs</a>
          </div>
          <div class="flex items-center gap-3">
            <a href="https://github.com/g-flame-oss/airlink-addons" target="_blank" class="hover:text-neutral-300 transition-colors">GitHub</a>
            <a href="https://github.com/g-flame-oss/airlink-addons/blob/modrinth-addon/LICENSE" target="_blank" class="hover:text-neutral-300 transition-colors">License</a>
            <a href="https://discord.gg/TQzUeg2wJx" target="_blank" class="hover:text-neutral-300 transition-colors">Discord</a>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('progress') %>

<div id="toast" class="fixed top-4 right-4 z-50 hidden">
  <div class="bg-neutral-900 border border-neutral-700 rounded-xl shadow-xl p-4 min-w-[280px]">
    <div class="flex items-start gap-3">
      <div id="toastIcon" class="flex-shrink-0 mt-0.5"></div>
      <div class="flex-1">
        <div id="toastTitle" class="font-medium text-white text-sm"></div>
        <div id="toastMessage" class="text-neutral-400 text-xs mt-0.5"></div>
      </div>
      <button onclick="hideToast()" class="text-neutral-600 hover:text-neutral-300 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
      </button>
    </div>
  </div>
</div>

<style>
  * { scrollbar-width: none; -ms-overflow-style: none; }
  *::-webkit-scrollbar { display: none; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    setupQuickFilters();
    setupViewToggle();
    setupFormValidation();
  });

  function showToast(message, type, duration) {
    type = type || 'info';
    duration = duration == null ? 4000 : duration;
    var icons = { success: { color: 'emerald', label: 'S' }, error: { color: 'red', label: 'E' }, warning: { color: 'amber', label: 'W' }, info: { color: 'blue', label: 'I' } };
    var cfg = icons[type] || icons.info;
    document.getElementById('toastIcon').innerHTML = '<div class="w-5 h-5 bg-' + cfg.color + '-600 rounded-full flex items-center justify-center text-white text-xs font-bold">' + cfg.label + '</div>';
    document.getElementById('toastTitle').textContent = type.charAt(0).toUpperCase() + type.slice(1);
    document.getElementById('toastMessage').textContent = message;
    document.getElementById('toast').classList.remove('hidden');
    if (duration > 0) setTimeout(hideToast, duration);
  }

  function hideToast() { document.getElementById('toast').classList.add('hidden'); }

  function setupQuickFilters() {
    document.querySelectorAll('.quick-filter').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelector('input[name="q"]').value = this.dataset.category;
        this.closest('form').submit();
      });
    });
  }

  function setupViewToggle() {
    var gridBtn = document.getElementById('gridViewBtn');
    var listBtn = document.getElementById('listViewBtn');
    var container = document.getElementById('resultsContainer');
    if (!gridBtn || !listBtn || !container) return;

    listBtn.addEventListener('click', function() {
      container.className = 'space-y-2';
      container.querySelectorAll('.project-card').forEach(function(card) {
        card.classList.remove('flex-col');
        card.classList.add('flex-row', 'items-center');
        var imgWrap = card.querySelector('.aspect-square');
        if (imgWrap) { imgWrap.classList.remove('aspect-square'); imgWrap.classList.add('w-16', 'h-16', 'flex-shrink-0'); }
      });
      listBtn.className = 'p-2 bg-emerald-600 text-white';
      gridBtn.className = 'p-2 text-neutral-400 hover:text-white transition-colors';
    });

    gridBtn.addEventListener('click', function() {
      container.className = 'grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4';
      container.querySelectorAll('.project-card').forEach(function(card) {
        card.classList.add('flex-col');
        card.classList.remove('flex-row', 'items-center');
        var imgWrap = card.querySelector('.w-16');
        if (imgWrap) { imgWrap.classList.add('aspect-square'); imgWrap.classList.remove('w-16', 'h-16', 'flex-shrink-0'); }
      });
      gridBtn.className = 'p-2 bg-emerald-600 text-white';
      listBtn.className = 'p-2 text-neutral-400 hover:text-white transition-colors';
    });
  }

  function setupFormValidation() {
    var form = document.querySelector('form[action="/modrinth"]');
    var typeSelect = document.querySelector('select[name="type"]');
    if (!form || !typeSelect) return;
    var settings = <%- JSON.stringify(modrinthSettings || {}) %>;
    form.addEventListener('submit', function(e) {
      var selected = typeSelect.value;
      if (selected !== 'all' && settings && settings.disabledProjectTypes && settings.disabledProjectTypes.includes(selected)) {
        e.preventDefault();
        showToast(selected + ' projects are disabled by admin', 'error', 5000);
        typeSelect.value = 'all';
      }
    });
  }
</script>

<%- include(components.footer) %>
