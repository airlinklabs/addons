<div id="deleteConfirmModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-[#111] border border-neutral-800 rounded-xl w-full max-w-sm">
    <div class="p-6 text-center">
      <div class="w-10 h-10 bg-red-500/10 border border-red-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-white mb-1">Delete backup?</h3>
      <p class="text-xs text-neutral-500 mb-1">You're about to delete</p>
      <p class="text-sm text-white font-medium mb-3" id="deleteBackupName"></p>
      <p class="text-xs text-red-400/80">This will remove it from Google Drive and cannot be undone.</p>
    </div>
    <div class="flex gap-3 px-5 pb-5">
      <button onclick="hideModal('deleteConfirmModal')"
        class="flex-1 py-2.5 text-sm text-neutral-400 hover:text-white bg-neutral-900 hover:bg-neutral-800 border border-neutral-800 rounded-lg transition-all">
        Cancel
      </button>
      <button onclick="handleDeleteBackup()"
        class="flex-1 py-2.5 text-sm text-white bg-red-600 hover:bg-red-500 rounded-lg transition-colors font-medium">
        Delete
      </button>
    </div>
  </div>
</div>

<script>
async function handleDeleteBackup() {
  hideModal('deleteConfirmModal');
  try {
    const { success, error } = await fetch(`/parachute/api/backup/${currentBackupId}/delete`, {
      method: 'POST',
    }).then(r => r.json());
    if (success) { showToast('Backup deleted', 'success'); loadBackups(); }
    else showToast(error || 'Failed to delete', 'error');
  } catch { showToast('Network error', 'error'); }
}
</script>
