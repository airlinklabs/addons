<%- include(components.header, { title: title, user: user }) %>

<%
  const isProjectTypeDisabled = modrinthSettings && modrinthSettings.modrinthInstallationWarning &&
    Array.isArray(modrinthSettings.disabledProjectTypes) &&
    modrinthSettings.disabledProjectTypes.includes(project.project_type);
  const isProjectBlocked = modrinthSettings &&
    Array.isArray(modrinthSettings.blockedProjects) &&
    modrinthSettings.blockedProjects.includes(project.id);
  const isAnyInstallationBlocked = isProjectTypeDisabled || isProjectBlocked;
%>

<main class="h-screen flex">
  <div class="w-60 h-full flex-shrink-0">
    <%- include(components.template) %>
  </div>

  <div class="flex-1 flex flex-col overflow-hidden pt-16">

    <div class="flex-shrink-0 border-b border-neutral-800 px-6 py-3 flex items-center justify-between">
      <a href="/modrinth" class="inline-flex items-center text-sm text-neutral-400 hover:text-white transition-colors group">
        <svg class="w-4 h-4 mr-2 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to store
      </a>
      <button onclick="openProgressModal()" class="flex items-center gap-2 px-3 py-1.5 bg-neutral-800 hover:bg-neutral-700 text-neutral-300 hover:text-white border border-neutral-700 rounded-lg text-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
        </svg>
        Installations
      </button>
    </div>

    <% if (isAnyInstallationBlocked) { %>
    <div class="flex-shrink-0 bg-amber-500/10 border-b border-amber-500/20 px-6 py-3 flex items-start gap-3">
      <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
      </svg>
      <div>
        <span class="font-medium text-amber-400 text-sm"><%= modrinthSettings.warningTitle || 'Installation Disabled' %></span>
        <span class="ml-2 text-amber-300/70 text-sm"><%= modrinthSettings.warningMessage || '' %></span>
        <div class="flex gap-2 mt-1.5">
          <% if (isProjectTypeDisabled) { %>
          <span class="text-xs text-amber-300 bg-amber-500/20 px-2 py-0.5 rounded"><%= project.project_type %> type disabled</span>
          <% } %>
          <% if (isProjectBlocked) { %>
          <span class="text-xs text-red-300 bg-red-500/20 px-2 py-0.5 rounded">This project is blocked</span>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>

    <div class="flex-1 overflow-y-auto no-scrollbar">

      <div class="border-b border-neutral-800 px-6 py-6">
        <div class="flex items-start gap-5">
          <% if (project.icon_url) { %>
          <img src="<%= project.icon_url %>" alt="<%= project.title %>" class="w-20 h-20 rounded-xl border border-neutral-700 flex-shrink-0" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
          <div class="w-20 h-20 bg-neutral-800 border border-neutral-700 rounded-xl flex items-center justify-center flex-shrink-0" style="display:none;">
            <svg class="w-10 h-10 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
          </div>
          <% } else { %>
          <div class="w-20 h-20 bg-neutral-800 border border-neutral-700 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-10 h-10 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
          </div>
          <% } %>

          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-2 flex-wrap">
              <h1 class="text-2xl font-bold text-white"><%= project.title %></h1>
              <span class="px-2.5 py-0.5 text-xs bg-emerald-600/20 text-emerald-400 border border-emerald-600/30 rounded-full font-medium"><%= project.project_type %></span>
              <% if (isAnyInstallationBlocked) { %>
              <span class="px-2.5 py-0.5 text-xs bg-red-600/20 text-red-400 border border-red-600/30 rounded-full font-medium">Install disabled</span>
              <% } %>
            </div>
            <p class="text-neutral-400 text-sm mb-4 leading-relaxed"><%= project.description %></p>
            <div class="flex items-center gap-5 text-sm text-neutral-500">
              <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-neutral-600" fill="currentColor" viewBox="0 0 20 20"><path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"></path></svg>
                <%= (project.downloads || 0).toLocaleString() %> downloads
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-neutral-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg>
                <%= (project.followers || 0).toLocaleString() %> followers
              </span>
              <span>Updated <%= project.updated ? new Date(project.updated).toLocaleDateString() : 'Unknown' %></span>
            </div>
            <% if (project.categories && Array.isArray(project.categories) && project.categories.length > 0) { %>
            <div class="flex flex-wrap gap-1.5 mt-3">
              <% project.categories.forEach(function(cat) { %>
              <span class="px-2 py-0.5 text-xs bg-neutral-800 text-neutral-400 border border-neutral-700 rounded-full"><%= cat %></span>
              <% }); %>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="flex gap-6 px-6 py-6">

        <div class="flex-1 min-w-0">
          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6">
            <h2 class="text-base font-semibold text-white mb-4">Description</h2>
            <% if (project.body) { %>
            <div id="project-body" class="markdown-content text-neutral-400 text-sm leading-relaxed"><%= project.body %></div>
            <% } else { %>
            <p class="text-neutral-400 text-sm leading-relaxed"><%= project.description %></p>
            <% } %>
          </div>
        </div>

        <div class="w-72 flex-shrink-0 space-y-4">

          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
            <h3 class="text-sm font-semibold text-white mb-3">Details</h3>
            <div class="space-y-2.5 text-sm">
              <% if (project.license && project.license.name) { %>
              <div class="flex justify-between items-center">
                <span class="text-neutral-500">License</span>
                <span class="text-neutral-300 text-xs bg-neutral-800 px-2 py-0.5 rounded"><%= project.license.name %></span>
              </div>
              <% } %>
              <% if (project.client_side) { %>
              <div class="flex justify-between items-center">
                <span class="text-neutral-500">Client side</span>
                <span class="text-neutral-300 text-xs capitalize bg-neutral-800 px-2 py-0.5 rounded"><%= project.client_side %></span>
              </div>
              <% } %>
              <% if (project.server_side) { %>
              <div class="flex justify-between items-center">
                <span class="text-neutral-500">Server side</span>
                <span class="text-neutral-300 text-xs capitalize bg-neutral-800 px-2 py-0.5 rounded"><%= project.server_side %></span>
              </div>
              <% } %>
              <% if (project.published) { %>
              <div class="flex justify-between items-center">
                <span class="text-neutral-500">Published</span>
                <span class="text-neutral-400 text-xs"><%= new Date(project.published).toLocaleDateString() %></span>
              </div>
              <% } %>
              <% if (isAnyInstallationBlocked) { %>
              <div class="pt-2 border-t border-neutral-800">
                <div class="flex justify-between items-center">
                  <span class="text-neutral-500">Installation</span>
                  <span class="text-red-400 text-xs bg-red-600/20 px-2 py-0.5 rounded border border-red-600/20">Disabled</span>
                </div>
              </div>
              <% } %>
            </div>
            <% const hasLinks = project.source_url || project.issues_url || project.wiki_url || project.discord_url; %>
            <% if (hasLinks) { %>
            <div class="mt-4 pt-4 border-t border-neutral-800 space-y-1">
              <% if (project.source_url) { %>
              <a href="<%= project.source_url %>" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-neutral-500 hover:text-white transition-colors p-1.5 rounded-lg hover:bg-neutral-800">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633z" clip-rule="evenodd"></path></svg>
                Source code
              </a>
              <% } %>
              <% if (project.issues_url) { %>
              <a href="<%= project.issues_url %>" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-neutral-500 hover:text-white transition-colors p-1.5 rounded-lg hover:bg-neutral-800">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Issues
              </a>
              <% } %>
              <% if (project.wiki_url) { %>
              <a href="<%= project.wiki_url %>" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-neutral-500 hover:text-white transition-colors p-1.5 rounded-lg hover:bg-neutral-800">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253"></path></svg>
                Wiki
              </a>
              <% } %>
              <% if (project.discord_url) { %>
              <a href="<%= project.discord_url %>" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-neutral-500 hover:text-white transition-colors p-1.5 rounded-lg hover:bg-neutral-800">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"></path></svg>
                Discord
              </a>
              <% } %>
            </div>
            <% } %>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-sm font-semibold text-white">Versions</h3>
              <% if (isAnyInstallationBlocked) { %>
              <span class="text-xs text-red-400 bg-red-600/20 px-2 py-0.5 rounded border border-red-600/20">Disabled</span>
              <% } %>
            </div>

            <% if (versions && Array.isArray(versions) && versions.length > 0) { %>
            <div class="space-y-2 max-h-96 overflow-y-auto no-scrollbar" id="versions-container">
              <% versions.slice(0, 5).forEach(function(version) { %>
              <div class="bg-neutral-800 border border-neutral-700 rounded-lg p-3 <%= isAnyInstallationBlocked ? 'opacity-60' : '' %>">
                <div class="flex items-start justify-between gap-2 mb-2">
                  <div class="flex-1 min-w-0">
                    <div class="text-white text-xs font-medium truncate"><%= version.name %></div>
                    <div class="text-neutral-500 text-xs font-mono mt-0.5"><%= version.version_number %></div>
                  </div>
                  <span class="text-xs px-1.5 py-0.5 rounded bg-emerald-600/20 text-emerald-400 border border-emerald-600/20 flex-shrink-0 font-medium"><%= version.version_type %></span>
                </div>

                <div class="text-xs text-neutral-600 space-y-1 mb-3">
                  <% if (version.game_versions && version.game_versions.length > 0) { %>
                  <div>
                    <span class="text-neutral-600">MC: </span>
                    <% version.game_versions.slice(0, 3).forEach(function(v, idx) { %>
                    <span class="text-neutral-400 font-mono"><%= v %></span><% if (idx < Math.min(2, version.game_versions.length - 1)) { %><span class="text-neutral-700">, </span><% } %>
                    <% }); %>
                    <% if (version.game_versions.length > 3) { %><span class="text-neutral-600"> +<%= version.game_versions.length - 3 %></span><% } %>
                  </div>
                  <% } %>
                  <% if (version.loaders && version.loaders.length > 0) { %>
                  <div class="flex flex-wrap gap-1 mt-1">
                    <% version.loaders.forEach(function(loader) { %><span class="text-neutral-400 font-mono text-xs bg-neutral-700 px-1.5 py-0.5 rounded"><%= loader %></span><% }); %>
                  </div>
                  <% } %>
                </div>

                <% if (!isAnyInstallationBlocked) { %>
                <button onclick="installVersion('<%= project.id %>', '<%= version.id %>')" class="w-full py-1.5 text-xs bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg transition-colors font-medium install-button">
                  Install
                </button>
                <% } else { %>
                <div class="w-full py-1.5 text-xs bg-neutral-700 text-neutral-500 rounded-lg font-medium text-center cursor-not-allowed">Installation disabled</div>
                <% } %>
              </div>
              <% }); %>
            </div>

            <% if (versions.length > 5) { %>
            <button onclick="showAllVersions()" class="w-full mt-3 py-2 text-xs text-neutral-500 hover:text-white bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 rounded-lg transition-colors font-medium">
              View all <%= versions.length %> versions
            </button>
            <% } %>
            <% } else { %>
            <div class="text-center py-6">
              <p class="text-neutral-600 text-sm">No versions available</p>
            </div>
            <% } %>
          </div>

        </div>
      </div>

      <div class="px-6 pb-6">
        <div class="pt-5 border-t border-neutral-800 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-neutral-600">
          <div class="flex items-center gap-1.5">
            <span>Modrinth store by</span>
            <a href="https://github.com/g-flame-oss" target="_blank" class="text-neutral-400 hover:text-white transition-colors">g-flame</a>
            <span>•</span>
            <span>Panel by</span>
            <a href="https://github.com/AirlinkLabs" target="_blank" class="text-neutral-400 hover:text-white transition-colors">AirlinkLabs</a>
          </div>
          <div class="flex items-center gap-3">
            <a href="https://github.com/g-flame-oss/airlink-addons" target="_blank" class="hover:text-neutral-300 transition-colors">GitHub</a>
            <a href="https://github.com/g-flame-oss/airlink-addons/blob/modrinth-addon/LICENSE" target="_blank" class="hover:text-neutral-300 transition-colors">License</a>
            <a href="https://discord.gg/TQzUeg2wJx" target="_blank" class="hover:text-neutral-300 transition-colors">Discord</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('progress') %>

<div id="allVersionsModal" class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 p-4">
  <div class="bg-neutral-900 border border-neutral-700 rounded-2xl w-full max-w-3xl max-h-[80vh] flex flex-col">
    <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-800">
      <h3 class="text-base font-semibold text-white">All versions</h3>
      <button onclick="closeAllVersionsModal()" class="text-neutral-500 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    <% if (isAnyInstallationBlocked) { %>
    <div class="px-6 py-3 bg-amber-500/10 border-b border-amber-500/20 flex items-center gap-2">
      <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
      <span class="text-amber-400 text-sm font-medium"><%= modrinthSettings.warningTitle || 'Installation disabled' %></span>
    </div>
    <% } %>
    <div id="allVersionsList" class="p-6 space-y-3 overflow-y-auto flex-1 no-scrollbar"></div>
  </div>
</div>

<div id="installModal" class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 p-4">
  <div class="bg-neutral-900 border border-neutral-700 rounded-2xl w-full max-w-md">
    <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-800">
      <h3 class="text-base font-semibold text-white">Select server</h3>
      <button onclick="closeInstallModal()" class="text-neutral-500 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    <div class="p-6">
      <div id="serversList" class="space-y-2 mb-5 max-h-60 overflow-y-auto no-scrollbar"></div>
      <div class="flex justify-end gap-2">
        <button onclick="closeInstallModal()" class="px-4 py-2 bg-neutral-800 hover:bg-neutral-700 text-neutral-300 border border-neutral-700 rounded-lg text-sm transition-colors">Cancel</button>
        <button id="confirmInstall" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-medium transition-colors">Install</button>
      </div>
    </div>
  </div>
</div>

<div id="toastContainer" class="fixed top-4 right-4 z-50 space-y-2"></div>

<style>
  * { scrollbar-width: none; -ms-overflow-style: none; }
  *::-webkit-scrollbar { display: none; }
  .markdown-content h1, .markdown-content h2, .markdown-content h3, .markdown-content h4 { color: #fff; margin-top: 1.5em; margin-bottom: 0.5em; font-weight: 600; }
  .markdown-content h1 { font-size: 1.5rem; }
  .markdown-content h2 { font-size: 1.25rem; }
  .markdown-content h3 { font-size: 1.1rem; }
  .markdown-content p { color: #a3a3a3; line-height: 1.7; margin-bottom: 1em; }
  .markdown-content ul, .markdown-content ol { color: #a3a3a3; margin-left: 1.5em; margin-bottom: 1em; }
  .markdown-content li { margin-bottom: 0.4em; }
  .markdown-content code { background: #262626; color: #fbbf24; padding: 0.1em 0.4em; border-radius: 0.3em; font-size: 0.875em; }
  .markdown-content pre { background: #171717; padding: 1em; border-radius: 0.75em; overflow-x: auto; margin: 1em 0; border: 1px solid #262626; }
  .markdown-content pre code { background: transparent; color: #d4d4d4; padding: 0; }
  .markdown-content a { color: #10b981; text-decoration: underline; }
  .markdown-content blockquote { border-left: 3px solid #404040; padding-left: 1em; margin: 1em 0; color: #737373; font-style: italic; }
  .markdown-content img { max-width: 100%; border-radius: 0.5em; margin: 1em 0; border: 1px solid #262626; }
</style>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
  var allVersions = [];
  var selectedProject = '';
  var selectedVersion = '';
  var selectedServer = null;
  var isProjectDisabled = false;

  document.addEventListener('DOMContentLoaded', function() {
    allVersions = <%- JSON.stringify(Array.isArray(versions) ? versions : []) %>;
    selectedProject = '<%= project && project.id ? project.id : "" %>';
    isProjectDisabled = <%= isAnyInstallationBlocked ? 'true' : 'false' %>;

    var bodyEl = document.getElementById('project-body');
    if (bodyEl && typeof marked !== 'undefined') {
      var md = bodyEl.textContent.trim();
      if (md) bodyEl.innerHTML = marked.parse(md);
    }
  });

  function showAllVersions() {
    var container = document.getElementById('allVersionsList');
    container.innerHTML = '';

    if (!allVersions || allVersions.length === 0) {
      container.innerHTML = '<p class="text-neutral-500 text-sm text-center py-8">No versions available</p>';
      openModal('allVersionsModal');
      return;
    }

    allVersions.forEach(function(version) {
      var gameVersions = Array.isArray(version.game_versions) ? version.game_versions : [];
      var loaders = Array.isArray(version.loaders) ? version.loaders : [];

      var div = document.createElement('div');
      div.className = 'bg-neutral-800 border border-neutral-700 rounded-lg p-4' + (isProjectDisabled ? ' opacity-60' : '');

      var html = '<div class="flex items-start justify-between gap-3">';
      html += '<div class="flex-1 min-w-0">';
      html += '<div class="flex items-center gap-2 mb-1"><span class="text-white text-sm font-medium truncate">' + escapeHtml(version.name || 'Unknown') + '</span>';
      html += '<span class="text-xs px-1.5 py-0.5 rounded bg-emerald-600/20 text-emerald-400 border border-emerald-600/20 flex-shrink-0">' + escapeHtml(version.version_type || 'release') + '</span></div>';
      html += '<div class="text-xs text-neutral-500 font-mono mb-2">' + escapeHtml(version.version_number || '') + '</div>';

      if (gameVersions.length > 0) {
        html += '<div class="text-xs text-neutral-600 mb-1">MC: ' + gameVersions.slice(0, 3).map(function(v) { return '<span class="text-neutral-400 font-mono">' + escapeHtml(v) + '</span>'; }).join(', ');
        if (gameVersions.length > 3) html += ' <span>+' + (gameVersions.length - 3) + '</span>';
        html += '</div>';
      }
      if (loaders.length > 0) {
        html += '<div class="flex flex-wrap gap-1">' + loaders.map(function(l) { return '<span class="text-neutral-400 font-mono text-xs bg-neutral-700 px-1.5 py-0.5 rounded">' + escapeHtml(l) + '</span>'; }).join('') + '</div>';
      }
      html += '</div>';

      if (!isProjectDisabled) {
        html += '<button onclick="installVersion(\'' + escapeHtml(selectedProject) + '\', \'' + escapeHtml(version.id) + '\')" class="px-3 py-1.5 text-xs bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg transition-colors font-medium flex-shrink-0">Install</button>';
      } else {
        html += '<div class="px-3 py-1.5 text-xs bg-neutral-700 text-neutral-500 rounded-lg flex-shrink-0 cursor-not-allowed">Disabled</div>';
      }
      html += '</div>';
      div.innerHTML = html;
      container.appendChild(div);
    });

    openModal('allVersionsModal');
  }

  function closeAllVersionsModal() { closeModal('allVersionsModal'); }

  function installVersion(projectId, versionId) {
    if (isProjectDisabled) { showNotification('Installation is disabled for this project', 'error'); return; }
    if (!projectId || !versionId) { showNotification('Invalid project or version', 'error'); return; }
    selectedProject = projectId;
    selectedVersion = versionId;

    fetch('/modrinth/api/servers', { credentials: 'include', headers: { 'Accept': 'application/json' } })
      .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function(data) {
        if (data.success && Array.isArray(data.data) && data.data.length > 0) {
          populateServersList(data.data);
          closeModal('allVersionsModal');
          openModal('installModal');
        } else {
          showNotification('No servers available', 'error');
        }
      })
      .catch(function(err) { showNotification('Failed to load servers', 'error'); });
  }

  function populateServersList(servers) {
    var list = document.getElementById('serversList');
    list.innerHTML = '';
    servers.forEach(function(server) {
      var div = document.createElement('div');
      div.className = 'flex items-center gap-3 p-3 bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 rounded-lg cursor-pointer transition-all';
      div.innerHTML = '<input type="radio" name="server" value="' + escapeHtml(server.id) + '" class="w-4 h-4 text-emerald-600 bg-neutral-700 border-neutral-600 focus:ring-emerald-500">' +
        '<div class="flex-1 min-w-0"><div class="text-white text-sm font-medium truncate">' + escapeHtml(server.name || 'Unnamed') + '</div>' +
        '<div class="text-neutral-500 text-xs mt-0.5">' + escapeHtml(server.description || '') + '</div></div>' +
        '<span class="text-xs px-2 py-0.5 rounded font-medium flex-shrink-0 ' + getStatusClass(server.status) + '">' + escapeHtml(server.status || 'unknown') + '</span>';
      div.addEventListener('click', function() {
        div.querySelector('input').checked = true;
        selectedServer = server.id;
        document.querySelectorAll('#serversList > div').forEach(function(d) { d.classList.remove('ring-2', 'ring-emerald-500'); });
        div.classList.add('ring-2', 'ring-emerald-500');
      });
      list.appendChild(div);
    });
  }

  function closeInstallModal() { closeModal('installModal'); selectedServer = null; }

  function getStatusClass(status) {
    if (status === 'running') return 'bg-emerald-600/20 text-emerald-400 border border-emerald-600/20';
    if (status === 'suspended') return 'bg-red-600/20 text-red-400 border border-red-600/20';
    return 'bg-neutral-700 text-neutral-400 border border-neutral-600';
  }

  function openModal(id) {
    var el = document.getElementById(id);
    el.classList.remove('hidden');
    el.classList.add('flex');
  }
  function closeModal(id) {
    var el = document.getElementById(id);
    el.classList.add('hidden');
    el.classList.remove('flex');
  }

  function escapeHtml(text) {
    if (typeof text !== 'string') return String(text || '');
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function showNotification(message, type, duration) {
    type = type || 'info';
    duration = duration == null ? 5000 : duration;
    var colors = { error: 'red', success: 'emerald', warning: 'amber', info: 'blue' };
    var color = colors[type] || 'blue';
    var titles = { error: 'Error', success: 'Success', warning: 'Warning', info: 'Info' };

    var toast = document.createElement('div');
    toast.className = 'bg-neutral-900 border border-neutral-700 rounded-xl shadow-xl p-4 min-w-[300px] max-w-sm';
    toast.innerHTML = '<div class="flex items-start gap-3">' +
      '<div class="w-5 h-5 bg-' + color + '-600 rounded-full flex-shrink-0 mt-0.5"></div>' +
      '<div class="flex-1 min-w-0"><div class="font-medium text-white text-sm">' + titles[type] + '</div>' +
      '<div class="text-neutral-400 text-xs mt-0.5">' + escapeHtml(message) + '</div></div>' +
      '<button onclick="this.parentElement.parentElement.remove()" class="text-neutral-600 hover:text-white transition-colors ml-1">' +
      '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg></button>' +
      '</div>';

    document.getElementById('toastContainer').appendChild(toast);
    if (duration > 0) setTimeout(function() { if (toast.parentElement) toast.remove(); }, duration);
  }

  document.getElementById('confirmInstall').addEventListener('click', function() {
    if (!selectedServer) { showNotification('Please select a server', 'error'); return; }
    var btn = this;
    btn.textContent = 'Installing...';
    btn.disabled = true;

    fetch('/modrinth/server/' + encodeURIComponent(selectedServer) + '/install', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ projectId: selectedProject, versionId: selectedVersion })
    })
    .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
    .then(function(result) {
      if (result.ok && result.data.success) {
        showNotification('Installation started', 'success');
        closeInstallModal();
        document.querySelectorAll('.install-button').forEach(function(b) { b.textContent = 'Installing...'; b.disabled = true; });
        setTimeout(function() {
          document.querySelectorAll('.install-button').forEach(function(b) { b.textContent = 'Install'; b.disabled = false; });
        }, 5000);
      } else {
        throw new Error(result.data.error || 'Installation failed');
      }
    })
    .catch(function(err) { showNotification(err.message, 'error'); })
    .finally(function() { btn.textContent = 'Install'; btn.disabled = false; });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeInstallModal(); closeAllVersionsModal(); }
  });
  ['allVersionsModal', 'installModal'].forEach(function(id) {
    var modal = document.getElementById(id);
    if (modal) modal.addEventListener('click', function(e) { if (e.target === this) closeModal(id); });
  });
</script>

<%- include(components.footer) %>
