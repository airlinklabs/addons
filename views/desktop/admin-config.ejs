<%- include(components.header, { title: title, user: user }) %>

<main class="h-screen flex">
  <div class="w-60 h-full flex-shrink-0">
    <%- include(components.template) %>
  </div>

  <div class="flex-1 flex flex-col overflow-hidden pt-16">

    <div class="flex-shrink-0 border-b border-neutral-800 px-6 py-3 flex items-center justify-between">
      <nav class="flex items-center gap-2 text-sm">
        <a href="/modrinth" class="text-neutral-500 hover:text-white transition-colors">Modrinth store</a>
        <svg class="w-3.5 h-3.5 text-neutral-700" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
        <span class="text-neutral-300">Admin config</span>
      </nav>
      <button onclick="openProgressModal()" class="flex items-center gap-2 px-3 py-1.5 bg-neutral-800 hover:bg-neutral-700 text-neutral-300 hover:text-white border border-neutral-700 rounded-lg text-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
        Installations
      </button>
    </div>

    <div class="flex-1 overflow-y-auto no-scrollbar">
      <div class="px-6 py-6 max-w-7xl">

        <!-- File status bar — full width -->
        <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-5 mb-5">
          <div class="flex items-center justify-between mb-3">
            <div>
              <h2 class="text-sm font-semibold text-neutral-900 dark:text-white">Config file</h2>
              <p class="text-neutral-500 text-xs mt-0.5">Stored at <code class="text-neutral-600 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-800 px-1.5 py-0.5 rounded font-mono">modrinth-settings.json</code></p>
            </div>
            <div class="flex gap-2">
              <button onclick="refreshFileStatus()" class="px-3 py-1.5 text-xs bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white border border-neutral-200 dark:border-neutral-700 rounded-lg transition-colors">Refresh</button>
              <button onclick="loadCurrentSettings()" class="px-3 py-1.5 text-xs bg-emerald-50 dark:bg-emerald-600/20 hover:bg-emerald-100 dark:hover:bg-emerald-600/30 text-emerald-700 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-600/30 rounded-lg transition-colors">Reload settings</button>
            </div>
          </div>
          <div id="fileStatus" class="flex items-center gap-2 p-3 bg-neutral-50 dark:bg-neutral-800 rounded-lg text-sm text-neutral-500">
            <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
            Loading file status...
          </div>
        </div>

        <!-- Two-column layout -->
        <div class="grid grid-cols-2 gap-5">

          <!-- Left column: Settings + Reference -->
          <div class="space-y-5">

            <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl">
              <div class="px-5 py-4 border-b border-neutral-200 dark:border-neutral-800">
                <h2 class="text-sm font-semibold text-neutral-900 dark:text-white">Settings</h2>
                <p class="text-neutral-500 text-xs mt-0.5">Toggle warning and manage disabled types</p>
              </div>
              <div class="p-5 space-y-5">

                <div>
                  <label class="flex items-center gap-3 cursor-pointer select-none">
                    <input type="checkbox" id="enableWarning" class="w-4 h-4 rounded border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-emerald-600 focus:ring-emerald-500 focus:ring-offset-0">
                    <span class="text-sm text-neutral-700 dark:text-neutral-300">Show installation warning banner</span>
                  </label>
                </div>

                <div class="space-y-3">
                  <div>
                    <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5" for="warningTitle">Warning title</label>
                    <input type="text" id="warningTitle" placeholder="Installation Temporarily Disabled" class="w-full px-3 py-2 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm text-neutral-900 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-600 focus:outline-none focus:border-emerald-500 transition-colors">
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5" for="warningMessage">Warning message</label>
                    <textarea id="warningMessage" rows="2" placeholder="Installations are temporarily disabled..." class="w-full px-3 py-2 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm text-neutral-900 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-600 focus:outline-none focus:border-emerald-500 transition-colors resize-none"></textarea>
                  </div>
                </div>

                <div>
                  <p class="text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-2">Disabled project types <span class="text-neutral-400 dark:text-neutral-600 font-normal">(click to toggle)</span></p>
                  <div id="projectTypeButtons" class="flex flex-wrap gap-2"></div>
                </div>

                <div>
                  <p class="text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-2">Blocked projects</p>
                  <div class="flex gap-2 mb-3">
                    <input type="text" id="newProjectId" placeholder="Project ID (e.g. fabric-api)" class="flex-1 px-3 py-2 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm text-neutral-900 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-600 focus:outline-none focus:border-emerald-500 transition-colors">
                    <button onclick="addBlockedProject()" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-medium transition-colors">Add</button>
                  </div>
                  <div id="blockedProjectsList" class="space-y-1.5"></div>
                </div>

                <div class="pt-4 border-t border-neutral-200 dark:border-neutral-800">
                  <button onclick="applyEasySettings()" class="px-5 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-medium transition-colors">Apply to JSON</button>
                </div>
              </div>
            </div>

            <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl p-5">
              <h2 class="text-sm font-semibold text-neutral-900 dark:text-white mb-4">Configuration reference</h2>
              <div class="grid grid-cols-2 gap-5">
                <div>
                  <p class="text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-2">Schema</p>
                  <pre class="bg-neutral-50 dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-800 rounded-lg p-4 text-xs text-neutral-600 dark:text-neutral-400 font-mono overflow-x-auto"><code>{
  "modrinthInstallationWarning": false,
  "warningTitle": "Installation Disabled",
  "warningMessage": "Details here.",
  "disabledProjectTypes": ["mod", "shader"],
  "blockedProjects": ["fabric-api"]
}</code></pre>
                </div>
                <div>
                  <p class="text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-2">Project types</p>
                  <div class="space-y-1.5">
                    <% [
                      { type: 'mod', desc: 'Client/server modifications' },
                      { type: 'modpack', desc: 'Collections of mods' },
                      { type: 'resourcepack', desc: 'Texture and sound packs' },
                      { type: 'shader', desc: 'Graphics enhancements' },
                      { type: 'datapack', desc: 'Data-driven mechanics' },
                      { type: 'plugin', desc: 'Server plugins' }
                    ].forEach(function(item) { %>
                    <div class="flex items-center justify-between py-1.5 px-2 rounded-lg bg-neutral-50 dark:bg-neutral-800/50 text-xs">
                      <code class="text-emerald-600 dark:text-emerald-400 font-mono"><%= item.type %></code>
                      <span class="text-neutral-500"><%= item.desc %></span>
                    </div>
                    <% }); %>
                  </div>
                </div>
              </div>
              <div class="mt-4 p-3 bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/20 rounded-lg text-xs text-blue-700 dark:text-blue-300/80 space-y-1">
                <p><span class="text-blue-700 dark:text-blue-300 font-medium">disabledProjectTypes</span> — hides that type entirely from browse results</p>
                <p><span class="text-blue-700 dark:text-blue-300 font-medium">blockedProjects</span> — keeps project visible but disables install button</p>
                <p><span class="text-blue-700 dark:text-blue-300 font-medium">Project IDs</span> — from Modrinth URLs, e.g. modrinth.com/mod/<span class="font-medium">fabric-api</span></p>
              </div>
            </div>

          </div>

          <!-- Right column: JSON editor -->
          <div>
            <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl">
              <div class="px-5 py-4 border-b border-neutral-200 dark:border-neutral-800 flex items-center justify-between">
                <div>
                  <h2 class="text-sm font-semibold text-neutral-900 dark:text-white">JSON editor</h2>
                  <p class="text-neutral-500 text-xs mt-0.5">Edit config directly — validated before saving</p>
                </div>
                <div class="flex gap-2">
                  <button onclick="formatJson()" class="px-3 py-1.5 text-xs bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white border border-neutral-200 dark:border-neutral-700 rounded-lg transition-colors">Format</button>
                  <button onclick="validateJson()" class="px-3 py-1.5 text-xs bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white border border-neutral-200 dark:border-neutral-700 rounded-lg transition-colors">Validate</button>
                  <button onclick="resetToDefaults()" class="px-3 py-1.5 text-xs bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white border border-neutral-200 dark:border-neutral-700 rounded-lg transition-colors">Reset</button>
                </div>
              </div>
              <div class="p-5">
                <textarea id="jsonEditor" rows="20" spellcheck="false" placeholder="Loading..." class="w-full px-4 py-3 bg-neutral-50 dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-800 rounded-lg text-sm text-neutral-800 dark:text-neutral-200 font-mono leading-relaxed focus:outline-none focus:border-emerald-500 transition-colors resize-none no-scrollbar"></textarea>
                <div class="flex items-center justify-between mt-2 text-xs text-neutral-500 dark:text-neutral-600">
                  <div class="flex items-center gap-4">
                    <span id="jsonValid" class="hidden text-emerald-600 dark:text-emerald-500">Valid JSON</span>
                    <span id="jsonInvalid" class="hidden text-red-500">Invalid JSON</span>
                    <span id="characterCount">0 characters</span>
                  </div>
                  <span>Ctrl+S to save</span>
                </div>
              </div>
              <div class="px-5 py-4 border-t border-neutral-200 dark:border-neutral-800 flex items-center justify-between">
                <div class="flex gap-2">
                  <button onclick="loadTemplate('restrictive')" class="px-3 py-1.5 text-xs bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white border border-neutral-200 dark:border-neutral-700 rounded-lg transition-colors">Restrictive template</button>
                  <button onclick="loadTemplate('permissive')" class="px-3 py-1.5 text-xs bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white border border-neutral-200 dark:border-neutral-700 rounded-lg transition-colors">Permissive template</button>
                </div>
                <button onclick="saveSettings()" class="px-5 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-medium transition-colors">Save config</button>
              </div>
            </div>
          </div>

        </div>

        <div class="pt-5 mt-5 border-t border-neutral-200 dark:border-neutral-800 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-neutral-400 dark:text-neutral-600">
          <div class="flex items-center gap-1.5">
            <span>Modrinth store by</span>
            <a href="https://github.com/g-flame-oss" target="_blank" class="text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors">g-flame</a>
            <span>•</span>
            <span>Panel by</span>
            <a href="https://github.com/AirlinkLabs" target="_blank" class="text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors">AirlinkLabs</a>
          </div>
          <div class="flex items-center gap-3">
            <a href="https://github.com/g-flame-oss/airlink-addons" target="_blank" class="hover:text-neutral-900 dark:hover:text-neutral-300 transition-colors">GitHub</a>
            <a href="https://github.com/g-flame-oss/airlink-addons/blob/modrinth-addon/LICENSE" target="_blank" class="hover:text-neutral-900 dark:hover:text-neutral-300 transition-colors">License</a>
            <a href="https://discord.gg/TQzUeg2wJx" target="_blank" class="hover:text-neutral-900 dark:hover:text-neutral-300 transition-colors">Discord</a>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('progress') %>

<div id="notification" class="fixed top-4 right-4 z-50 hidden">
  <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 rounded-xl shadow-xl p-4 min-w-[280px]">
    <div class="flex items-start gap-3">
      <div id="notificationIcon" class="flex-shrink-0 mt-0.5"></div>
      <div class="flex-1">
        <div id="notificationTitle" class="font-medium text-neutral-900 dark:text-white text-sm"></div>
        <div id="notificationMessage" class="text-neutral-500 dark:text-neutral-400 text-xs mt-0.5"></div>
      </div>
      <button onclick="hideNotification()" class="text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-300 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
      </button>
    </div>
  </div>
</div>

<style>
  * { scrollbar-width: none; -ms-overflow-style: none; }
  *::-webkit-scrollbar { display: none; }
</style>

<script>
  var currentSettings = <%- JSON.stringify(modrinthSettings || {}) %>;

  var PROJECT_TYPES = ['mod', 'modpack', 'resourcepack', 'shader', 'datapack', 'plugin'];

  document.addEventListener('DOMContentLoaded', function() {
    loadCurrentSettings();
    refreshFileStatus();
    setupProjectTypeButtons();
    setupJsonEditor();
    document.getElementById('newProjectId').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') addBlockedProject();
    });
  });

  function setupProjectTypeButtons() {
    var container = document.getElementById('projectTypeButtons');
    if (!container) return;
    container.innerHTML = '';
    PROJECT_TYPES.forEach(function(type) {
      var btn = document.createElement('button');
      btn.setAttribute('data-type', type);
      btn.className = 'project-type-btn px-3 py-1.5 text-xs border rounded-lg font-medium transition-colors bg-neutral-100 dark:bg-neutral-800 border-neutral-200 dark:border-neutral-700 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-400 dark:hover:border-neutral-500';
      btn.textContent = type;
      btn.addEventListener('click', function() { toggleProjectType(type); });
      container.appendChild(btn);
    });
  }

  function updateProjectTypeButtons() {
    try {
      var settings = JSON.parse(document.getElementById('jsonEditor').value);
      var disabled = settings.disabledProjectTypes || [];
      document.querySelectorAll('.project-type-btn').forEach(function(btn) {
        var type = btn.getAttribute('data-type');
        if (disabled.includes(type)) {
          btn.className = 'project-type-btn px-3 py-1.5 text-xs border rounded-lg font-medium transition-colors bg-red-50 dark:bg-red-600/20 border-red-200 dark:border-red-600/40 text-red-600 dark:text-red-400';
        } else {
          btn.className = 'project-type-btn px-3 py-1.5 text-xs border rounded-lg font-medium transition-colors bg-neutral-100 dark:bg-neutral-800 border-neutral-200 dark:border-neutral-700 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-400 dark:hover:border-neutral-500';
        }
      });
    } catch (e) {}
  }

  function toggleProjectType(type) {
    try {
      var settings = JSON.parse(document.getElementById('jsonEditor').value);
      if (!Array.isArray(settings.disabledProjectTypes)) settings.disabledProjectTypes = [];
      var idx = settings.disabledProjectTypes.indexOf(type);
      if (idx > -1) { settings.disabledProjectTypes.splice(idx, 1); } else { settings.disabledProjectTypes.push(type); }
      updateJsonEditor(settings);
      updateProjectTypeButtons();
    } catch (e) { showNotification('Error', 'Could not parse JSON', 'error'); }
  }

  function addBlockedProject() {
    var input = document.getElementById('newProjectId');
    var id = input.value.trim();
    if (!id) { showNotification('Error', 'Enter a project ID', 'error'); return; }
    try {
      var settings = JSON.parse(document.getElementById('jsonEditor').value);
      if (!Array.isArray(settings.blockedProjects)) settings.blockedProjects = [];
      if (settings.blockedProjects.includes(id)) { showNotification('Warning', 'Already blocked', 'warning'); return; }
      settings.blockedProjects.push(id);
      updateJsonEditor(settings);
      updateBlockedProjectsList();
      input.value = '';
      showNotification('Added', '"' + id + '" added to blocked list', 'success');
    } catch (e) { showNotification('Error', 'Could not parse JSON', 'error'); }
  }

  function removeBlockedProject(id) {
    try {
      var settings = JSON.parse(document.getElementById('jsonEditor').value);
      if (!Array.isArray(settings.blockedProjects)) return;
      var idx = settings.blockedProjects.indexOf(id);
      if (idx > -1) { settings.blockedProjects.splice(idx, 1); updateJsonEditor(settings); updateBlockedProjectsList(); }
    } catch (e) { showNotification('Error', 'Could not update', 'error'); }
  }

  function updateBlockedProjectsList() {
    var container = document.getElementById('blockedProjectsList');
    if (!container) return;
    try {
      var settings = JSON.parse(document.getElementById('jsonEditor').value);
      var list = settings.blockedProjects || [];
      if (list.length === 0) {
        container.innerHTML = '<p class="text-xs text-neutral-600 italic">No blocked projects</p>';
        return;
      }
      container.innerHTML = list.map(function(id) {
        return '<div class="flex items-center justify-between p-2.5 bg-red-50 dark:bg-red-600/10 border border-red-200 dark:border-red-600/20 rounded-lg">' +
          '<code class="text-xs font-mono text-red-600 dark:text-red-400">' + escapeHtml(id) + '</code>' +
          '<button onclick="removeBlockedProject(\'' + escapeHtml(id) + '\')" class="text-neutral-400 hover:text-red-500 dark:hover:text-red-400 transition-colors">' +
          '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg></button></div>';
      }).join('');
    } catch (e) {}
  }

  function applyEasySettings() {
    try {
      var settings = JSON.parse(document.getElementById('jsonEditor').value);
      settings.modrinthInstallationWarning = document.getElementById('enableWarning').checked;
      settings.warningTitle = document.getElementById('warningTitle').value.trim() || 'Installation Temporarily Disabled';
      settings.warningMessage = document.getElementById('warningMessage').value.trim() || '';
      updateJsonEditor(settings);
      showNotification('Updated', 'Settings applied to JSON', 'success');
    } catch (e) { showNotification('Error', 'Could not parse JSON', 'error'); }
  }

  function loadCurrentSettings() {
    fetch('/modrinth/api/config', { credentials: 'include' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success && data.data) {
          currentSettings = data.data;
          updateJsonEditor(currentSettings);
          updateEasyUI(currentSettings);
          updateProjectTypeButtons();
          updateBlockedProjectsList();
        }
      })
      .catch(function() {
        if (currentSettings) {
          updateJsonEditor(currentSettings);
          updateEasyUI(currentSettings);
          updateProjectTypeButtons();
          updateBlockedProjectsList();
        }
      });
  }

  function updateEasyUI(settings) {
    var enableWarning = document.getElementById('enableWarning');
    var warningTitle = document.getElementById('warningTitle');
    var warningMessage = document.getElementById('warningMessage');
    if (enableWarning) enableWarning.checked = !!settings.modrinthInstallationWarning;
    if (warningTitle) warningTitle.value = settings.warningTitle || '';
    if (warningMessage) warningMessage.value = settings.warningMessage || '';
  }

  function updateJsonEditor(settings) {
    var editor = document.getElementById('jsonEditor');
    editor.value = JSON.stringify(settings, null, 2);
    updateCharacterCount();
  }

  function setupJsonEditor() {
    var editor = document.getElementById('jsonEditor');
    editor.addEventListener('input', updateCharacterCount);
    editor.addEventListener('keydown', function(e) {
      if (e.ctrlKey && e.key === 's') { e.preventDefault(); saveSettings(); }
      if (e.ctrlKey && e.key === 'Enter') { e.preventDefault(); formatJson(); }
    });
  }

  function updateCharacterCount() {
    var editor = document.getElementById('jsonEditor');
    document.getElementById('characterCount').textContent = editor.value.length + ' characters';
    document.getElementById('jsonValid').classList.add('hidden');
    document.getElementById('jsonInvalid').classList.add('hidden');
  }

  function formatJson() {
    var editor = document.getElementById('jsonEditor');
    try {
      editor.value = JSON.stringify(JSON.parse(editor.value), null, 2);
      updateCharacterCount();
      showNotification('Formatted', 'JSON formatted', 'success', 2000);
    } catch (e) { showNotification('Error', 'Invalid JSON — cannot format', 'error'); }
  }

  function validateJson() {
    var editor = document.getElementById('jsonEditor');
    try {
      JSON.parse(editor.value);
      document.getElementById('jsonValid').classList.remove('hidden');
      document.getElementById('jsonInvalid').classList.add('hidden');
      showNotification('Valid', 'JSON is valid', 'success', 2000);
    } catch (e) {
      document.getElementById('jsonValid').classList.add('hidden');
      document.getElementById('jsonInvalid').classList.remove('hidden');
      showNotification('Invalid', e.message, 'error');
    }
  }

  function resetToDefaults() {
    var defaults = { modrinthInstallationWarning: false, warningTitle: 'Installation Temporarily Disabled', warningMessage: 'Installations are temporarily disabled.', disabledProjectTypes: [], blockedProjects: [] };
    updateJsonEditor(defaults);
    updateEasyUI(defaults);
    updateProjectTypeButtons();
    updateBlockedProjectsList();
    showNotification('Reset', 'Defaults loaded', 'info');
  }

  function loadTemplate(type) {
    var templates = {
      restrictive: { modrinthInstallationWarning: true, warningTitle: 'Installation Disabled', warningMessage: 'Mod installation is currently restricted.', disabledProjectTypes: ['shader', 'resourcepack'], blockedProjects: [] },
      permissive: { modrinthInstallationWarning: false, warningTitle: '', warningMessage: '', disabledProjectTypes: [], blockedProjects: [] }
    };
    var t = templates[type];
    if (!t) return;
    updateJsonEditor(t);
    updateEasyUI(t);
    updateProjectTypeButtons();
    updateBlockedProjectsList();
    showNotification('Loaded', type + ' template loaded', 'success', 2000);
  }

  function saveSettings() {
    var editor = document.getElementById('jsonEditor');
    var parsed;
    try { parsed = JSON.parse(editor.value); } catch (e) { showNotification('Error', 'Invalid JSON — fix before saving', 'error'); return; }
    fetch('/modrinth/admin/config', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify(parsed)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) { showNotification('Saved', 'Configuration saved', 'success'); }
      else { throw new Error(data.error || 'Save failed'); }
    })
    .catch(function(e) { showNotification('Error', e.message, 'error'); });
  }

  function refreshFileStatus() {
    fetch('/modrinth/api/file-status', { credentials: 'include' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var el = document.getElementById('fileStatus');
        if (data.success && data.data) {
          var f = data.data;
          el.innerHTML = '<div class="flex items-center gap-2"><div class="w-2 h-2 bg-emerald-500 rounded-full"></div><span class="text-sm text-neutral-700 dark:text-neutral-300">File found</span></div>' +
            (f.size ? '<span class="text-xs text-neutral-400 dark:text-neutral-600 ml-4">' + f.size + ' bytes</span>' : '') +
            (f.lastModified ? '<span class="text-xs text-neutral-400 dark:text-neutral-600 ml-2">Modified ' + new Date(f.lastModified).toLocaleString() + '</span>' : '');
        } else {
          el.innerHTML = '<div class="flex items-center gap-2"><div class="w-2 h-2 bg-amber-500 rounded-full"></div><span class="text-sm text-neutral-500 dark:text-neutral-400">File not found — will be created on save</span></div>';
        }
      })
      .catch(function() {
        document.getElementById('fileStatus').innerHTML = '<div class="flex items-center gap-2"><div class="w-2 h-2 bg-red-500 rounded-full"></div><span class="text-sm text-neutral-500">Could not check file status</span></div>';
      });
  }

  function escapeHtml(text) {
    if (typeof text !== 'string') return String(text || '');
    var d = document.createElement('div'); d.textContent = text; return d.innerHTML;
  }

  function showNotification(title, message, type, duration) {
    type = type || 'info';
    duration = duration == null ? 4000 : duration;
    var svgs = {
      success: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>',
      error:   '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>',
      warning: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path></svg>',
      info:    '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
    };
    var colors = { error: 'red', success: 'emerald', warning: 'amber', info: 'blue' };
    var color = colors[type] || 'blue';
    document.getElementById('notificationIcon').innerHTML = '<div class="w-7 h-7 bg-' + color + '-600 rounded-full flex items-center justify-center text-white flex-shrink-0">' + (svgs[type] || svgs.info) + '</div>';
    document.getElementById('notificationTitle').textContent = title;
    document.getElementById('notificationMessage').textContent = message;
    document.getElementById('notification').classList.remove('hidden');
    if (duration > 0) setTimeout(hideNotification, duration);
  }

  function hideNotification() { document.getElementById('notification').classList.add('hidden'); }

  function loadStatistics() {}
</script>

