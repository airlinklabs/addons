<div id="createBackupModal" class="hidden fixed inset-0 bg-black/40 dark:bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl w-full max-w-md shadow-2xl flex flex-col">
    <div class="flex items-start justify-between px-5 py-4 border-b border-neutral-200 dark:border-neutral-800">
      <div>
        <h2 class="text-sm font-semibold text-neutral-900 dark:text-white">Create backup</h2>
        <p class="text-xs text-neutral-500 mt-0.5">Compressed and uploaded to your storage provider</p>
      </div>
      <button onclick="hideModal('createBackupModal')" class="text-neutral-400 hover:text-neutral-700 dark:hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="p-5 space-y-4">
      <div>
        <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Name <span class="text-red-500">*</span></label>
        <input type="text" id="backupName" maxlength="100" placeholder="e.g. Pre-update snapshot"
          class="w-full px-3 py-2.5 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm text-neutral-900 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-600 focus:outline-none focus:border-neutral-400 dark:focus:border-neutral-600 transition-colors">
      </div>

      <div>
        <label class="flex items-center gap-2.5 cursor-pointer select-none">
          <input type="checkbox" id="useEncryption" onchange="toggleEncryption()"
            class="w-4 h-4 rounded border-neutral-300 dark:border-neutral-600 text-emerald-600 focus:ring-emerald-500 focus:ring-offset-0">
          <span class="text-sm text-neutral-700 dark:text-neutral-300">Encrypt with password</span>
        </label>
      </div>

      <div id="encryptionFields" class="hidden space-y-3 pl-6 border-l-2 border-neutral-200 dark:border-neutral-800">
        <div>
          <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Password <span class="text-red-500">*</span></label>
          <input type="password" id="backupPassword" placeholder="Choose a strong password"
            class="w-full px-3 py-2.5 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm text-neutral-900 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-600 focus:outline-none focus:border-amber-400 dark:focus:border-amber-600/50 transition-colors">
        </div>
        <div>
          <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Hint <span class="text-neutral-400 dark:text-neutral-600">(optional)</span></label>
          <input type="text" id="passwordHint" maxlength="200" placeholder="Something to jog your memory"
            class="w-full px-3 py-2.5 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm text-neutral-900 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-600 focus:outline-none focus:border-neutral-400 dark:focus:border-neutral-600 transition-colors">
        </div>
      </div>

      <div class="bg-amber-50 dark:bg-amber-500/5 border border-amber-200 dark:border-amber-500/15 rounded-lg px-4 py-3">
        <p class="text-xs text-amber-700 dark:text-amber-400/80">Large servers may take 5–15 minutes. Keep this page open.</p>
      </div>
    </div>

    <div class="flex gap-2.5 px-5 py-4 border-t border-neutral-200 dark:border-neutral-800">
      <button onclick="hideModal('createBackupModal')"
        class="flex-1 py-2.5 text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 border border-neutral-200 dark:border-neutral-700 rounded-lg transition-all">
        Cancel
      </button>
      <button id="createBackupBtn" onclick="handleCreateBackup()"
        class="flex-1 py-2.5 text-sm text-white bg-emerald-600 hover:bg-emerald-500 rounded-lg transition-colors font-medium">
        Create backup
      </button>
    </div>
  </div>
</div>

<script>
function toggleEncryption() {
  const on = document.getElementById('useEncryption').checked;
  document.getElementById('encryptionFields').classList.toggle('hidden', !on);
  if (!on) { document.getElementById('backupPassword').value = ''; document.getElementById('passwordHint').value = ''; }
}

async function handleCreateBackup() {
  const name = document.getElementById('backupName').value.trim();
  const encrypt = document.getElementById('useEncryption').checked;
  const password = encrypt ? document.getElementById('backupPassword').value : undefined;
  const hint = encrypt ? document.getElementById('passwordHint').value.trim() : undefined;

  if (!name) { showToast('Backup name is required', 'error'); return; }
  if (encrypt && !password) { showToast('Password is required when encryption is enabled', 'error'); return; }

  const btn = document.getElementById('createBackupBtn');
  btn.disabled = true; btn.textContent = 'Creating…';
  hideModal('createBackupModal');
  showToast('Backup started — this may take several minutes', 'info', 0);

  try {
    const res = await fetch('/parachute/api/backup/create', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ serverUUID: currentServerUUID, name, password, passwordHint: hint }),
    });
    const { success, error } = await res.json();
    if (success) {
      showToast('Backup created successfully', 'success');
      document.getElementById('backupName').value = '';
      document.getElementById('useEncryption').checked = false;
      document.getElementById('encryptionFields').classList.add('hidden');
      loadBackups();
    } else { showToast(error || 'Failed to create backup', 'error', 8000); }
  } catch { showToast('Network error — backup may have failed', 'error', 8000); }
  finally { btn.disabled = false; btn.textContent = 'Create backup'; }
}
</script>
