<div id="restoreBackupModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-[#111] border border-neutral-800 rounded-xl w-full max-w-md max-h-[90vh] flex flex-col">
    <div class="flex items-start justify-between px-5 py-4 border-b border-neutral-800 flex-shrink-0">
      <div>
        <h2 class="text-sm font-semibold text-white">Restore backup</h2>
        <p class="text-xs text-neutral-500 mt-0.5">Current server files will be replaced</p>
      </div>
      <button onclick="hideModal('restoreBackupModal')" class="text-neutral-600 hover:text-white transition-colors mt-0.5">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="p-5 overflow-y-auto flex-1 space-y-4">
      <div id="restorePasswordGroup" class="hidden">
        <label class="block text-xs font-medium text-neutral-400 mb-1.5">Backup password <span class="text-red-400">*</span></label>
        <input type="password" id="restorePassword" placeholder="Enter the backup password"
          class="w-full px-3 py-2.5 bg-neutral-900 border border-neutral-800 rounded-lg text-sm text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-600 transition-colors">
        <p class="text-xs text-amber-400/70 mt-1.5">This backup is encrypted</p>
      </div>

      <div class="bg-red-500/5 border border-red-500/15 rounded-lg p-4 space-y-1">
        <p class="text-xs font-medium text-red-400">All current server files will be deleted</p>
        <p class="text-xs text-neutral-600">This cannot be undone. The server will stop during restore.</p>
      </div>

      <label class="flex items-start gap-2.5 cursor-pointer">
        <input type="checkbox" id="confirmRestore"
          class="mt-0.5 w-4 h-4 rounded bg-neutral-800 border-neutral-700 text-emerald-600 focus:ring-emerald-500 focus:ring-offset-0">
        <span class="text-xs text-neutral-400 leading-relaxed">I understand this will overwrite all current server files and cannot be undone</span>
      </label>
    </div>

    <div class="flex gap-3 px-5 py-4 border-t border-neutral-800 flex-shrink-0">
      <button onclick="hideModal('restoreBackupModal')"
        class="flex-1 py-2.5 text-sm text-neutral-400 hover:text-white bg-neutral-900 hover:bg-neutral-800 border border-neutral-800 rounded-lg transition-all">
        Cancel
      </button>
      <button onclick="handleRestoreBackup()"
        class="flex-1 py-2.5 text-sm text-white bg-emerald-600 hover:bg-emerald-500 rounded-lg transition-colors font-medium">
        Restore
      </button>
    </div>
  </div>
</div>

<script>
async function handleRestoreBackup() {
  if (!document.getElementById('confirmRestore').checked) {
    showToast('Please confirm you understand the risks', 'error'); return;
  }
  const pwGroup = document.getElementById('restorePasswordGroup');
  const password = !pwGroup.classList.contains('hidden') ? document.getElementById('restorePassword').value : undefined;
  if (!pwGroup.classList.contains('hidden') && !password) {
    showToast('Password required for encrypted backups', 'error'); return;
  }
  hideModal('restoreBackupModal');
  showToast('Restore started — this may take several minutes', 'info', 0);
  try {
    const { success, error } = await fetch(`/parachute/api/backup/${currentBackupId}/restore`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ serverUUID: currentServerUUID, password }),
    }).then(r => r.json());
    if (success) {
      showToast('Backup restored successfully', 'success');
      document.getElementById('confirmRestore').checked = false;
    } else {
      showToast(error || 'Failed to restore backup', 'error', 8000);
    }
  } catch {
    showToast('Network error — restore may have failed', 'error', 8000);
  }
}
</script>
