<div id="restoreBackupModal" class="hidden fixed inset-0 bg-black/40 dark:bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl w-full max-w-md shadow-2xl flex flex-col">
    <div class="flex items-start justify-between px-5 py-4 border-b border-neutral-200 dark:border-neutral-800">
      <div>
        <h2 class="text-sm font-semibold text-neutral-900 dark:text-white">Restore backup</h2>
        <p class="text-xs text-neutral-500 mt-0.5">Current server files will be replaced</p>
      </div>
      <button onclick="hideModal('restoreBackupModal')" class="text-neutral-400 hover:text-neutral-700 dark:hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="p-5 space-y-4">
      <div id="restorePasswordGroup" class="hidden">
        <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Backup password <span class="text-red-500">*</span></label>
        <input type="password" id="restorePassword" placeholder="Enter the backup password"
          class="w-full px-3 py-2.5 bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm text-neutral-900 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-600 focus:outline-none focus:border-neutral-400 dark:focus:border-neutral-600 transition-colors">
        <p class="text-xs text-amber-600 dark:text-amber-400/80 mt-1.5 flex items-center gap-1">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          This backup is encrypted
        </p>
      </div>

      <div class="bg-red-50 dark:bg-red-500/5 border border-red-200 dark:border-red-500/15 rounded-lg px-4 py-3 space-y-1">
        <p class="text-xs font-medium text-red-600 dark:text-red-400">All current server files will be replaced</p>
        <p class="text-xs text-neutral-500 dark:text-neutral-600">This cannot be undone. The server will stop during restore.</p>
      </div>

      <label class="flex items-start gap-2.5 cursor-pointer">
        <input type="checkbox" id="confirmRestore"
          class="mt-0.5 w-4 h-4 rounded border-neutral-300 dark:border-neutral-600 text-emerald-600 focus:ring-emerald-500 focus:ring-offset-0">
        <span class="text-xs text-neutral-600 dark:text-neutral-400 leading-relaxed">I understand this will overwrite all current server files and cannot be undone</span>
      </label>
    </div>

    <div class="flex gap-2.5 px-5 py-4 border-t border-neutral-200 dark:border-neutral-800">
      <button onclick="hideModal('restoreBackupModal')"
        class="flex-1 py-2.5 text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg transition-all">
        Cancel
      </button>
      <button onclick="handleRestoreBackup()"
        class="flex-1 py-2.5 text-sm text-white bg-emerald-600 hover:bg-emerald-500 rounded-lg transition-colors font-medium">
        Restore
      </button>
    </div>
  </div>
</div>

<script>
async function handleRestoreBackup() {
  if (!document.getElementById('confirmRestore').checked) { showToast('Please confirm you understand the risks', 'error'); return; }
  const pwGroup = document.getElementById('restorePasswordGroup');
  const password = !pwGroup.classList.contains('hidden') ? document.getElementById('restorePassword').value : undefined;
  if (!pwGroup.classList.contains('hidden') && !password) { showToast('Password required for encrypted backups', 'error'); return; }
  hideModal('restoreBackupModal');
  showToast('Restore started — this may take several minutes', 'info', 0);
  try {
    const { success, error } = await fetch(`/parachute/api/backup/${currentBackupId}/restore`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ serverUUID: currentServerUUID, password }),
    }).then(r => r.json());
    if (success) { showToast('Backup restored successfully', 'success'); document.getElementById('confirmRestore').checked = false; }
    else showToast(error || 'Failed to restore backup', 'error', 8000);
  } catch { showToast('Network error — restore may have failed', 'error', 8000); }
}
</script>
