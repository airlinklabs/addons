<div id="renameBackupModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-[#111] border border-neutral-800 rounded-xl w-full max-w-sm">
    <div class="flex items-start justify-between px-5 py-4 border-b border-neutral-800">
      <div>
        <h2 class="text-sm font-semibold text-white">Rename backup</h2>
        <p class="text-xs text-neutral-500 mt-0.5">Only changes the label</p>
      </div>
      <button onclick="hideModal('renameBackupModal')" class="text-neutral-600 hover:text-white transition-colors mt-0.5">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="p-5">
      <label class="block text-xs font-medium text-neutral-400 mb-1.5">New name <span class="text-red-400">*</span></label>
      <input type="text" id="renameInput" maxlength="100" placeholder="Backup name"
        class="w-full px-3 py-2.5 bg-neutral-900 border border-neutral-800 rounded-lg text-sm text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-600 transition-colors">
    </div>
    <div class="flex gap-3 px-5 pb-5">
      <button onclick="hideModal('renameBackupModal')"
        class="flex-1 py-2.5 text-sm text-neutral-400 hover:text-white bg-neutral-900 hover:bg-neutral-800 border border-neutral-800 rounded-lg transition-all">
        Cancel
      </button>
      <button onclick="handleRenameBackup()"
        class="flex-1 py-2.5 text-sm text-white bg-neutral-700 hover:bg-neutral-600 rounded-lg transition-colors font-medium">
        Save
      </button>
    </div>
  </div>
</div>

<script>
async function handleRenameBackup() {
  const name = document.getElementById('renameInput').value.trim();
  if (!name) { showToast('Name is required', 'error'); return; }
  hideModal('renameBackupModal');
  try {
    const { success, error } = await fetch(`/parachute/api/backup/${currentBackupId}/rename`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name }),
    }).then(r => r.json());
    if (success) { showToast('Backup renamed', 'success'); loadBackups(); }
    else showToast(error || 'Failed to rename', 'error');
  } catch { showToast('Network error', 'error'); }
}
</script>
