<!-- Connected state -->
<div id="providerConnected" class="hidden">
  <div class="flex items-center gap-3 mb-3">
    <img id="providerPicture" src="" alt="" class="w-8 h-8 rounded-full bg-neutral-200 dark:bg-neutral-800 flex-shrink-0">
    <div class="min-w-0">
      <p class="text-sm font-medium text-neutral-900 dark:text-white truncate" id="providerName">—</p>
      <p class="text-xs text-neutral-500 truncate" id="providerEmail">—</p>
    </div>
  </div>
  <div class="flex items-center gap-1.5 text-xs text-neutral-500 mb-3 px-2 py-1.5 bg-neutral-100 dark:bg-neutral-800 rounded-md">
    <svg class="w-3.5 h-3.5 text-neutral-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
    </svg>
    <span class="truncate font-mono" id="providerFolder">—</span>
  </div>
  <div class="flex items-center gap-2">
    <span class="flex items-center gap-1.5 text-xs text-emerald-600 dark:text-emerald-400">
      <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
      <span id="providerLabel">Connected</span>
    </span>
    <button onclick="disconnectProvider()" class="ml-auto text-xs text-neutral-400 hover:text-red-500 transition-colors">Disconnect</button>
  </div>
</div>

<!-- Disconnected state -->
<div id="providerDisconnected" class="hidden">
  <p class="text-sm font-medium text-neutral-900 dark:text-white mb-1">Connect storage</p>
  <p class="text-xs text-neutral-500 mb-4 leading-relaxed">Connect a storage provider to start backing up your servers.</p>

  <div class="space-y-2">
    <% var gd = parachuteSettings && parachuteSettings.providers && parachuteSettings.providers.google_drive; %>
    <% if (gd && gd.enabled) { %>
    <a href="/parachute/oauth/google/connect"
      class="flex items-center gap-2.5 px-3 py-2.5 bg-white dark:bg-neutral-900 hover:bg-neutral-50 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm transition-colors group">
      <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <span class="text-neutral-700 dark:text-neutral-300 text-sm">Google Drive</span>
      <svg class="w-3.5 h-3.5 text-neutral-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
    <% } else { %>
    <div class="flex items-center gap-2.5 px-3 py-2.5 bg-neutral-50 dark:bg-neutral-900/50 border border-neutral-200 dark:border-neutral-800 rounded-lg text-sm opacity-40 cursor-not-allowed">
      <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <span class="text-neutral-500 dark:text-neutral-400 text-sm">Google Drive</span>
      <span class="ml-auto text-xs text-neutral-400 dark:text-neutral-600">not configured</span>
    </div>
    <% } %>

    <% var wd = parachuteSettings && parachuteSettings.providers && parachuteSettings.providers.webdav; %>
    <% if (wd && wd.enabled) { %>
    <button onclick="connectWebdav()"
      class="w-full flex items-center gap-2.5 px-3 py-2.5 bg-white dark:bg-neutral-900 hover:bg-neutral-50 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm transition-colors text-left">
      <svg class="w-4 h-4 text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
      </svg>
      <span class="text-neutral-700 dark:text-neutral-300 text-sm">WebDAV</span>
      <svg class="w-3.5 h-3.5 text-neutral-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
    <% } else { %>
    <div class="flex items-center gap-2.5 px-3 py-2.5 bg-neutral-50 dark:bg-neutral-900/50 border border-neutral-200 dark:border-neutral-800 rounded-lg text-sm opacity-40 cursor-not-allowed">
      <svg class="w-4 h-4 text-blue-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
      </svg>
      <span class="text-neutral-500 dark:text-neutral-400 text-sm">WebDAV</span>
      <span class="ml-auto text-xs text-neutral-400 dark:text-neutral-600">not configured</span>
    </div>
    <% } %>

    <% var db = parachuteSettings && parachuteSettings.providers && parachuteSettings.providers.dropbox; %>
    <% if (db && db.enabled) { %>
    <a href="/parachute/oauth/dropbox/connect"
      class="flex items-center gap-2.5 px-3 py-2.5 bg-white dark:bg-neutral-900 hover:bg-neutral-50 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm transition-colors group">
      <svg class="w-4 h-4 text-blue-600 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2.5L7 6l5 3.5L7 13l-5-3.5L7 6 2 2.5 7 6zm0 0L17 6l-5 3.5L17 13l5-3.5L17 6l5-3.5zm0 11.5l-5 3.5 5 3.5 5-3.5z"/>
      </svg>
      <span class="text-neutral-700 dark:text-neutral-300 text-sm">Dropbox</span>
      <svg class="w-3.5 h-3.5 text-neutral-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
    <% } else { %>
    <div class="flex items-center gap-2.5 px-3 py-2.5 bg-neutral-50 dark:bg-neutral-900/50 border border-neutral-200 dark:border-neutral-800 rounded-lg text-sm opacity-40 cursor-not-allowed">
      <svg class="w-4 h-4 text-blue-600 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2.5L7 6l5 3.5L7 13l-5-3.5L7 6 2 2.5 7 6zm0 0L17 6l-5 3.5L17 13l5-3.5L17 6l5-3.5zm0 11.5l-5 3.5 5 3.5 5-3.5z"/>
      </svg>
      <span class="text-neutral-500 dark:text-neutral-400 text-sm">Dropbox</span>
      <span class="ml-auto text-xs text-neutral-400 dark:text-neutral-600">not configured</span>
    </div>
    <% } %>

    <% var s3 = parachuteSettings && parachuteSettings.providers && parachuteSettings.providers.s3; %>
    <% if (s3 && s3.enabled) { %>
    <button onclick="connectS3()"
      class="w-full flex items-center gap-2.5 px-3 py-2.5 bg-white dark:bg-neutral-900 hover:bg-neutral-50 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm transition-colors text-left">
      <svg class="w-4 h-4 text-orange-500 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
      </svg>
      <span class="text-neutral-700 dark:text-neutral-300 text-sm">S3 / R2 / MinIO</span>
      <svg class="w-3.5 h-3.5 text-neutral-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
    <% } else { %>
    <div class="flex items-center gap-2.5 px-3 py-2.5 bg-neutral-50 dark:bg-neutral-900/50 border border-neutral-200 dark:border-neutral-800 rounded-lg text-sm opacity-40 cursor-not-allowed">
      <svg class="w-4 h-4 text-orange-500 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
      </svg>
      <span class="text-neutral-500 dark:text-neutral-400 text-sm">S3 / R2 / MinIO</span>
      <span class="ml-auto text-xs text-neutral-400 dark:text-neutral-600">not configured</span>
    </div>
    <% } %>

    <% var ftp = parachuteSettings && parachuteSettings.providers && parachuteSettings.providers.ftp; %>
    <% if (ftp && ftp.enabled) { %>
    <button onclick="connectFtp()"
      class="w-full flex items-center gap-2.5 px-3 py-2.5 bg-white dark:bg-neutral-900 hover:bg-neutral-50 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-sm transition-colors text-left">
      <svg class="w-4 h-4 text-neutral-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
      </svg>
      <span class="text-neutral-700 dark:text-neutral-300 text-sm">FTP / SFTP</span>
      <svg class="w-3.5 h-3.5 text-neutral-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
    <% } else { %>
    <div class="flex items-center gap-2.5 px-3 py-2.5 bg-neutral-50 dark:bg-neutral-900/50 border border-neutral-200 dark:border-neutral-800 rounded-lg text-sm opacity-40 cursor-not-allowed">
      <svg class="w-4 h-4 text-neutral-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
      </svg>
      <span class="text-neutral-500 dark:text-neutral-400 text-sm">FTP / SFTP</span>
      <span class="ml-auto text-xs text-neutral-400 dark:text-neutral-600">not configured</span>
    </div>
    <% } %>
  </div>
</div>

<script>
function connectWebdav() {
  fetch('/parachute/api/connect/webdav', { method: 'POST', credentials: 'include' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) { showToast('Connected to WebDAV', 'success'); updateAuthStatus(); loadBackups(); }
      else showToast(data.error || 'Failed to connect', 'error');
    })
    .catch(function() { showToast('Network error', 'error'); });
}

function connectS3() {
  fetch('/parachute/api/connect/s3', { method: 'POST', credentials: 'include' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) { showToast('Connected to S3', 'success'); updateAuthStatus(); loadBackups(); }
      else showToast(data.error || 'Failed to connect', 'error');
    })
    .catch(function() { showToast('Network error', 'error'); });
}

function connectFtp() {
  fetch('/parachute/api/connect/ftp', { method: 'POST', credentials: 'include' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) { showToast('Connected to FTP', 'success'); updateAuthStatus(); loadBackups(); }
      else showToast(data.error || 'Failed to connect', 'error');
    })
    .catch(function() { showToast('Network error', 'error'); });
}
</script>
