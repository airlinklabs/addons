# Google OAuth2 Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Application URL (used for OAuth callback)
# Example: https://panel.yourdomain.com or http://localhost:3000 (if you are using this when in the oauth screen at the last screen click f12 and go to network section then click reload page click confirm in the google oauth again you will see a callback request in the request in the section click on it and copy its the big url it has with localhost:3000 on it copy this and paste in the address bar and replace loaclhost with the ip of your server and clcik enter)
APP_URL=https://your-panel-url.com

# Cookie encryption secret (generate a random string)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PARACHUTE_COOKIE_SECRET=your_random_secret_key_here

# Node environment
NODE_ENV=production